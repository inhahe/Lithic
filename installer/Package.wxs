<?xml version="1.0" encoding="UTF-8"?>
<!--
  LithicBackup installer (WiX Toolset v4+ / built with the `wix` dotnet tool).

  Produces a per-machine MSI that:
    * installs the self-contained GUI + Worker into "Program Files\Lithic Backup"
      (no .NET runtime prerequisite — the publish output is self-contained),
    * installs and starts the "Lithic Backup" Windows service (the Worker), so the
      background backup engine is ready out of the box,
    * adds a Start Menu shortcut for the GUI, and
    * registers a normal Add/Remove Programs uninstaller that stops + removes the
      service and deletes all installed files.

  Build inputs live in .\publish (populated by build-installer.ps1 via
  `dotnet publish`).  Version is passed in with `-d Version=x.y.z`.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <?define Version = "$(var.Version)" ?>

  <Package
      Name="Lithic Backup"
      Manufacturer="Lithic"
      Version="$(Version)"
      UpgradeCode="7BC4E6C1-51A6-4D2C-9936-20C21DC77254"
      Scope="perMachine"
      Compressed="yes">

    <!-- Block same/older reinstalls with a clear message; allow upgrades. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of Lithic Backup is already installed." />

    <!--
      Close the running GUI before touching files.  Unlike the Worker (a service
      the installer can stop via SCM), LithicBackup.exe is an interactive app,
      and it minimizes to the tray on a plain WM_CLOSE instead of exiting - so
      the Restart Manager's polite close request just hides it and the process
      keeps its .exe locked, producing "Setup was unable to automatically close
      the application" on upgrade.

      EndSessionMessage sends WM_QUERYENDSESSION, which the app now treats as a
      real exit (App.OnSessionEnding), so it shuts down gracefully.  If it hasn't
      exited by the timeout, TerminateProcess force-closes it as a fallback so
      the upgrade can always proceed.  RebootPrompt="no" avoids demanding a
      reboot if a stubborn instance lingers.
    -->
    <util:CloseApplication
        Id="CloseLithicGui"
        Target="LithicBackup.exe"
        Description="Please close Lithic Backup so the upgrade can replace its files."
        CloseMessage="no"
        EndSessionMessage="yes"
        TerminateProcess="1"
        RebootPrompt="no" />

    <MediaTemplate EmbedCab="yes" />

    <Icon Id="AppIcon" SourceFile="publish\LithicBackup.exe" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/" />

    <!-- Install location: 64-bit Program Files. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Lithic Backup" />
    </StandardDirectory>

    <!-- Start Menu folder for the app shortcut. -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutFolder" Name="Lithic Backup" />
    </StandardDirectory>

    <!--
      Bulk-harvest every published file EXCEPT the Worker executable, which is
      installed by its own component (below) so a ServiceInstall can be attached.
    -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="publish\**">
        <Exclude Files="publish\LithicBackup.Worker.exe" />
        <Exclude Files="publish\LithicBackup.exe" />
      </Files>
    </ComponentGroup>

    <!--
      The GUI executable, installed by its own component so it has a stable File
      Id ("AppExe") that the "Launch Lithic Backup" custom action can reference
      via [#AppExe] (resolves to the full install path at runtime).
    -->
    <Component Id="AppExeComponent"
               Directory="INSTALLFOLDER"
               Guid="4B0F2E7A-9C1D-4E5B-8A62-1F3C7D9A4E80"
               Bitness="always64">
      <File Id="AppExe" Source="publish\LithicBackup.exe" KeyPath="yes" />
    </Component>

    <!--
      The Worker executable + the Windows service it backs.  The service runs as
      LocalSystem (matching the app's own sc.exe install) so it shares the
      ProgramData catalog with the interactive GUI.  Started on install; stopped
      and removed on uninstall.
    -->
    <Component Id="WorkerService"
               Directory="INSTALLFOLDER"
               Guid="DD535A49-6F70-48E7-926D-7149ED93F0A0"
               Bitness="always64">
      <File Id="WorkerExe" Source="publish\LithicBackup.Worker.exe" KeyPath="yes" />

      <ServiceInstall Id="WorkerServiceInstall"
                      Name="Lithic Backup"
                      DisplayName="Lithic Backup Worker"
                      Description="Runs scheduled and on-demand Lithic Backup backups in the background."
                      Type="ownProcess"
                      Start="auto"
                      ErrorControl="normal"
                      Account="LocalSystem"
                      Vital="no" />

      <!--
        Stop the running Worker on BOTH install and uninstall, and wait for it
        to fully stop.  The "install" half is what matters for upgrades/reinstalls:
        the elevated installer stops the service itself (via SCM) before touching
        files, so its exe is never locked.  Without this the Restart Manager sees
        the worker holding its own .exe, can't gracefully close a service, and
        falls back to the "unable to automatically close all requested
        applications" dialog.  Remove happens only on uninstall.
      -->
      <ServiceControl Id="WorkerServiceStopRemove"
                      Name="Lithic Backup"
                      Stop="both"
                      Remove="uninstall"
                      Wait="yes" />

      <!-- Start (or restart) on install, after the stop above has completed. -->
      <ServiceControl Id="WorkerServiceStart"
                      Name="Lithic Backup"
                      Start="install"
                      Wait="no" />
    </Component>

    <!-- Start Menu shortcut for the GUI. -->
    <Component Id="AppShortcut"
               Directory="AppShortcutFolder"
               Guid="C96CEDA6-142F-4896-904C-34EA8C8466B1"
               Bitness="always64">
      <Shortcut Id="StartMenuShortcut"
                Name="Lithic Backup"
                Description="Disc and directory backup"
                Target="[INSTALLFOLDER]LithicBackup.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveAppShortcutFolder" Directory="AppShortcutFolder" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\Lithic\LithicBackup"
                     Name="installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <Feature Id="Main" Title="Lithic Backup" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="AppExeComponent" />
      <ComponentRef Id="WorkerService" />
      <ComponentRef Id="AppShortcut" />
    </Feature>

    <!-- Classic install wizard with directory chooser + license page. -->
    <ui:WixUI xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
              Id="WixUI_InstallDir"
              InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!--
      Offer to launch the GUI from the final wizard page.  Uses the WixUI exit
      dialog's built-in optional checkbox (checked by default), wired to a
      WixShellExec custom action that starts LithicBackup.exe.  Impersonate="yes"
      so the app runs as the installing user, not the elevated installer account;
      asyncNoWait so the wizard closes immediately without blocking on the app.

      Why this never launches after a FAILED/CANCELLED install:
        * WixUI routes outcomes to different dialogs - success -> ExitDialog
          (this one), user cancel -> UserExit, fatal error/rollback -> FatalError.
          Only ExitDialog carries the launch checkbox + DoAction, so a cancel or
          a rolled-back install can't reach this launch at all.
        * The one path that could once show ExitDialog with the app NOT actually
          updated was "files in use -> user declines to close -> file swap
          deferred to the next reboot -> transaction succeeds with a reboot
          pending", which then offered to launch the still-old exe.  We remove
          that path at the source: util:CloseApplication (above) force-closes the
          GUI before file transfer, so nothing is ever in use and no reboot is
          ever scheduled - ExitDialog therefore only appears after a genuinely
          complete install.

      Conditions on the launch:
        * WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1  - the user left the box ticked.
        * NOT Installed                         - a first-time install or a
          major upgrade (the new package is not yet registered), never a repair,
          modify, or uninstall.
    -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Lithic Backup" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WixShellExecTarget" Value="[#AppExe]" />
    <CustomAction Id="LaunchApplication"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixShellExec"
                  Impersonate="yes" />

    <UI>
      <Publish Dialog="ExitDialog"
               Control="Finish"
               Event="DoAction"
               Value="LaunchApplication"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed and NOT REMOVE" />
    </UI>

  </Package>
</Wix>
