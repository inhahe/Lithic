<UserControl x:Class="LithicBackup.Views.TestDiscView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LithicBackup.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TestDiscViewModel, IsDesignTimeCreatable=False}">

    <DockPanel Margin="8">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource H2}" Text="Test Disc" />
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,2,0,0">
                <Run Text="Backup set: " />
                <Run Text="{Binding BackupSetName, Mode=OneWay}"
                     FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"
                       Text="Insert a disc from this set, then test it against the catalog. If it fails, you can re-burn a fresh replacement disc or just re-burn the affected files onto a new supplementary disc." />
        </StackPanel>

        <!-- Configuration: disc + drive pickers -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}"
                Padding="16,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Disc to test -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Disc to test:"
                           VerticalAlignment="Center" Margin="0,0,12,8"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" FontWeight="SemiBold" />
                <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"
                          ItemsSource="{Binding Discs}"
                          SelectedItem="{Binding SelectedDisc}"
                          DisplayMemberPath="Display"
                          IsEnabled="{Binding IsIdle}"
                          ToolTip="Choose which recorded disc from this set you are testing." />

                <!-- Optical drive -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Inserted in drive:"
                           VerticalAlignment="Center" Margin="0,0,12,8"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" FontWeight="SemiBold" />
                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding Drives}"
                              SelectedItem="{Binding SelectedDrive}"
                              DisplayMemberPath="Display"
                              IsEnabled="{Binding IsIdle}"
                              ToolTip="The mounted optical drive holding the disc. Auto-detected by matching the disc label." />
                    <Button Grid.Column="1" Content="Refresh"
                            Command="{Binding RefreshDrivesCommand}"
                            Padding="12,6" Margin="8,0,0,0" Cursor="Hand"
                            ToolTip="Re-scan optical drives (after inserting or swapping a disc)." />
                </Grid>

                <!-- Verify contents -->
                <CheckBox Grid.Row="2" Grid.Column="1"
                          Content="Verify file contents (read &amp; re-hash — slower)"
                          IsChecked="{Binding VerifyContents}"
                          IsEnabled="{Binding IsIdle}"
                          VerticalAlignment="Center" Cursor="Hand" Margin="0,4,0,0"
                          ToolTip="When checked, every stored file and block on the disc is read back and its SHA-256 re-computed to catch bit-rot on a decaying disc. When unchecked, only existence and size are checked." />
            </Grid>
        </Border>

        <!-- Progress indicator -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="{Binding IsProgressIndeterminate}"
                         Minimum="0" Maximum="100"
                         Value="{Binding ProgressPercent, Mode=OneWay}"
                         Height="4" Margin="0,0,0,8"
                         Foreground="{StaticResource PrimaryBrush}" />
            <TextBlock Text="{Binding ProgressText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       FontSize="12" />
        </StackPanel>

        <!-- Bottom bar: Test on the left, remediation + close on the right -->
        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <!-- Test (left) -->
            <Button Content="Test Disc" Command="{Binding TestCommand}"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Left"
                    Padding="16,8" Cursor="Hand"
                    ToolTip="Run the integrity test on the inserted disc." />

            <!-- Actions (right) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding ReplaceAffectedFilesCommand}"
                        Content="{Binding AffectedFileCount}"
                        ContentStringFormat="Re-burn {0:N0} affected file(s)"
                        Visibility="{Binding CanReplaceAffected, Converter={StaticResource BoolToVis}}"
                        Padding="16,8" Margin="0,0,8,0" Cursor="Hand"
                        ToolTip="Re-burn only the files that failed onto a new supplementary disc. The old disc's good files are kept; the failed records are superseded by the fresh copies." />
                <Button Content="Re-burn whole disc"
                        Command="{Binding ReplaceWholeDiscCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Visibility="{Binding HasFailure, Converter={StaticResource BoolToVis}}"
                        Padding="16,8" Margin="0,0,8,0" Cursor="Hand"
                        ToolTip="Re-stage every file this disc held from the live sources and burn a fresh replacement disc." />
                <Button Content="Close" Command="{Binding CloseCommand}"
                        Padding="16,8" Cursor="Hand" />
            </StackPanel>
        </Grid>

        <!-- Results -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding TestCompleted, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <!-- Stats grid -->
                <Border Style="{StaticResource Card}" Padding="16,12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Files checked -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="Files Checked"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding FilesChecked, StringFormat=N0}"
                                       FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Result -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="Result"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="FAILED" />
                                        <Setter Property="Foreground" Value="#C62828" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Succeeded}" Value="True">
                                                <Setter Property="Text" Value="PASSED" />
                                                <Setter Property="Foreground" Value="#2E7D32" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Issues -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="Issues"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding IssueCount, StringFormat=N0}"
                                       FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#C62828" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Succeeded}" Value="True">
                                                <Setter Property="Foreground" Value="#2E7D32" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Summary text -->
                <TextBlock Text="{Binding SummaryText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <!-- Issues list -->
                <Expander Header="{Binding IssueCount, StringFormat='Issues ({0:N0})'}"
                          IsExpanded="True"
                          Visibility="{Binding HasIssues, Converter={StaticResource BoolToVis}}">
                    <Border BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource SurfaceBrush}"
                            MaxHeight="380">
                        <ListView ItemsSource="{Binding Issues}"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="8,3" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Kind}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#C62828"
                                                   FontSize="11" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Path}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Path}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="11" />
                                            <TextBlock Text="{Binding Detail}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="10" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
