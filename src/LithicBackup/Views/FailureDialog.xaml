<Window x:Class="LithicBackup.Views.FailureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:LithicBackup.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:FailureDialogViewModel, IsDesignTimeCreatable=False}"
        Title="File Backup Failed"
        Width="520" Height="300"
        MinWidth="400" MinHeight="250"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- File path -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="File:" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="{Binding FilePath}" TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,2,0,0" />
        </StackPanel>

        <!-- Error message -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Error:" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                       Foreground="#FFCC4444"
                       Margin="0,2,0,0" />
        </StackPanel>

        <!-- Spacer -->
        <Border Grid.Row="2" />

        <!-- Apply to all checkbox -->
        <CheckBox Grid.Row="3"
                  Content="Apply to all remaining failures on this disc"
                  IsChecked="{Binding ApplyToAll, Mode=TwoWay}"
                  Margin="0,0,0,12"
                  Foreground="{StaticResource TextPrimaryBrush}" />

        <!-- Buttons -->
        <WrapPanel Grid.Row="4" HorizontalAlignment="Right">
            <Button Content="Skip" Click="OnSkip"
                    Padding="14,6" Margin="0,0,6,0" Cursor="Hand" />
            <Button Content="Retry" Click="OnRetry"
                    Padding="14,6" Margin="0,0,6,0" Cursor="Hand" />
            <Button Content="Zip" Click="OnZip"
                    Padding="14,6" Margin="0,0,6,0" Cursor="Hand"
                    ToolTip="Zip the file and retry (may resolve path incompatibilities)" />
            <Button Content="Skip All (Disc)" Click="OnSkipAllForDisc"
                    Padding="14,6" Margin="0,0,6,0" Cursor="Hand"
                    ToolTip="Skip all remaining failures on this disc" />
            <Button Content="Skip All (Permanent)" Click="OnSkipAllPermanently"
                    Padding="14,6" Cursor="Hand"
                    ToolTip="Skip all remaining failures permanently" />
        </WrapPanel>
    </Grid>
</Window>
