<Window x:Class="LithicBackup.Views.FailureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:LithicBackup.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:FailureDialogViewModel, IsDesignTimeCreatable=False}"
        Title="File Backup Failed"
        Width="520" Height="300"
        MinWidth="400" MinHeight="250"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- File path -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="File:" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="{Binding FilePath}" TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,2,0,0" />
        </StackPanel>

        <!-- Error message -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Error:" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                       Foreground="#FFCC4444"
                       Margin="0,2,0,0" />
        </StackPanel>

        <!-- Spacer -->
        <Border Grid.Row="2" />

        <!-- Apply to all checkbox -->
        <CheckBox Grid.Row="3"
                  IsChecked="{Binding ApplyToAll, Mode=TwoWay}"
                  Margin="0,0,0,12"
                  Foreground="{StaticResource TextPrimaryBrush}">
            <CheckBox.Style>
                <Style TargetType="CheckBox">
                    <Setter Property="Content" Value="Apply to all remaining failures on this disc" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDirectoryMode}" Value="True">
                            <Setter Property="Content" Value="Apply to all remaining failures" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </CheckBox.Style>
        </CheckBox>

        <!-- Buttons -->
        <WrapPanel Grid.Row="4" HorizontalAlignment="Right">
            <Button Content="Skip" Click="OnSkip"
                    Padding="14,6" Margin="0,0,6,0" Cursor="Hand" />
            <Button Content="Retry" Click="OnRetry"
                    Padding="14,6" Margin="0,0,6,0" Cursor="Hand" />

            <!-- Disc-burn only: Zip and Skip All (Disc) -->
            <Button Content="Zip" Click="OnZip"
                    Padding="14,6" Margin="0,0,6,0" Cursor="Hand"
                    ToolTip="Zip the file and retry (may resolve path incompatibilities)">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDirectoryMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Zip All (Disc)" Click="OnZipAllForDisc"
                    Padding="14,6" Margin="0,0,6,0" Cursor="Hand"
                    ToolTip="Zip all remaining failures on this disc">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDirectoryMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Skip All (Disc)" Click="OnSkipAllForDisc"
                    Padding="14,6" Margin="0,0,6,0" Cursor="Hand"
                    ToolTip="Skip all remaining failures on this disc">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDirectoryMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="Skip All" Click="OnSkipAllPermanently"
                    Padding="14,6" Margin="0,0,6,0" Cursor="Hand"
                    ToolTip="Skip all remaining failures" />

            <!-- Abort the entire backup -->
            <Button Content="Abort" Click="OnAbort"
                    Padding="14,6" Cursor="Hand"
                    ToolTip="Abort the entire backup"
                    Foreground="#FFCC4444" />
        </WrapPanel>
    </Grid>
</Window>
