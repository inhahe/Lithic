<UserControl x:Class="LithicBackup.Views.OrphanedDirectoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LithicBackup.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:OrphanedDirectoriesViewModel, IsDesignTimeCreatable=False}">

    <DockPanel>
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource H2}" Text="Orphaned Directories" />
            <TextBlock Style="{StaticResource SubText}"
                       Text="{Binding SummaryText}" />

            <!-- Exclusion pattern scanner -->
            <Border Style="{StaticResource Card}" Padding="10" Margin="0,10,0,0">
                <StackPanel>
                    <TextBlock Text="Scan for Excluded Files" FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,0,0,8"
                               Text="Enter exclusion patterns to find catalogued files that should be purged (e.g. *.log, */.vs/*, */bin/*)." />
                    <StackPanel Orientation="Horizontal">
                        <TextBox Text="{Binding ExclusionPatterns, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4" Width="400"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 ToolTip="Comma-separated patterns (e.g. *.log, temp_*, */.vs/*, */bin/*)" />
                        <Button Content="Scan" Command="{Binding ScanExcludedCommand}"
                                Padding="12,6" Margin="8,0,0,0" Cursor="Hand" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Command="{Binding CloseCommand}"
                    Padding="16,8" Margin="0,0,8,0" Cursor="Hand" />
            <Button Style="{StaticResource PrimaryButton}"
                    Content="Purge Selected" Command="{Binding PurgeSelectedCommand}" />
        </StackPanel>

        <!-- Directory list -->
        <Border BorderThickness="1"
                BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource SurfaceBrush}">
            <DockPanel>
                <!-- Column header row -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="8,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding IsAllSelected, Mode=TwoWay}"
                                  IsThreeState="True"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"
                                  ToolTip="Select/deselect all" />
                        <TextBlock Grid.Column="1" Text="Directory"
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="Status"
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="Files"
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right" />
                        <TextBlock Grid.Column="4" Text="Size"
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right" />
                    </Grid>
                </Border>

                <!-- Items -->
                <ListView ItemsSource="{Binding Items}"
                          BorderThickness="0"
                          Background="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="8,4" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DirectoryPath}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           ToolTip="{Binding DirectoryPath}" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding ReasonText}"
                                           VerticalAlignment="Center"
                                           FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Reason}"
                                                             Value="{x:Static vm:OrphanedReason.DeletedFromDisk}">
                                                    <Setter Property="Foreground" Value="#C62828" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Reason}"
                                                             Value="{x:Static vm:OrphanedReason.RemovedFromSources}">
                                                    <Setter Property="Foreground" Value="#EF6C00" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Reason}"
                                                             Value="{x:Static vm:OrphanedReason.MatchesExclusionPattern}">
                                                    <Setter Property="Foreground" Value="#6A1B9A" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding FileCount}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" />
                                <TextBlock Grid.Column="4"
                                           Text="{Binding SizeText}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>
        </Border>
    </DockPanel>
</UserControl>
