<Window x:Class="LithicBackup.Views.BackupSetEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LithicBackup.ViewModels"
        xmlns:views="clr-namespace:LithicBackup.Views"
        Style="{StaticResource MainWindowStyle}"
        Title="Modify Backup Set"
        SizeToContent="Height" Width="950"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Opacity="0">

    <Border Style="{StaticResource Card}" Margin="12">
        <ContentControl x:Name="ContentArea">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:SourceSelectionViewModel}">
                    <views:SourceSelectionView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:BackupJobViewModel}">
                    <views:BackupJobView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:LargestFilesViewModel}">
                    <views:LargestFilesView />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Border>
</Window>
