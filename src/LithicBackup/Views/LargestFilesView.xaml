<UserControl x:Class="LithicBackup.Views.LargestFilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LithicBackup.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:LargestFilesViewModel, IsDesignTimeCreatable=False}">

    <DockPanel Margin="8">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Style="{StaticResource H2}" Text="{Binding ViewTitle}" />
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,2,0,0">
                <Run Text="Backup set: " />
                <Run Text="{Binding BackupSetName, Mode=OneWay}"
                     FontWeight="SemiBold" />
            </TextBlock>

            <!-- Files / Directories toggle -->
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Command="{Binding ShowFilesCommand}" Cursor="Hand"
                        Padding="8,4" Margin="0,0,4,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0,0,0,2" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDirectoryMode}" Value="False">
                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="Files">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDirectoryMode}" Value="False">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <Button Command="{Binding ShowDirectoriesCommand}" Cursor="Hand"
                        Padding="8,4">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0,0,0,2" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDirectoryMode}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="Directories">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDirectoryMode}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- Loading indicator -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="{Binding IsProgressIndeterminate}"
                         Minimum="0" Maximum="100"
                         Value="{Binding ScanPercent, Mode=OneWay}"
                         Height="14" Margin="0,0,0,8"
                         Foreground="{StaticResource PrimaryBrush}" />
            <TextBlock Text="{Binding ScanProgressText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <!-- Bottom: summary + buttons -->
        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding SummaryText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12"
                       VerticalAlignment="Center" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding SaveStatusText}"
                           Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,12,0" />
                <Button Content="Save" Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Padding="16,8" Margin="0,0,8,0" Cursor="Hand" />
                <Button Content="Close" Command="{Binding CloseCommand}"
                        Padding="16,8" Cursor="Hand" />
            </StackPanel>
        </Grid>

        <!-- Content area (FILL) — single Border, hidden during loading.
             File list and directory tree overlap inside; visibility toggles by mode. -->
        <Border BorderThickness="1"
                BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource SurfaceBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <!-- ==================== FILE LIST ==================== -->
                <ListView ItemsSource="{Binding FilesView}"
                          BorderThickness="0"
                          Background="Transparent"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.Style>
                        <Style TargetType="ListView">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDirectoryMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.Style>

                    <!-- Custom template: column headers above a named ScrollViewer
                         so we can compensate the header margin when the scrollbar appears. -->
                    <ListView.Template>
                        <ControlTemplate TargetType="ListView">
                            <DockPanel>
                                <!-- Column headers -->
                                <Grid DockPanel.Dock="Top">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ComputedVerticalScrollBarVisibility, ElementName=FileListScroll}" Value="Visible">
                                                    <Setter Property="Margin" Value="0,0,17,0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" MinWidth="120" />
                                        <ColumnDefinition Width="1.5*" MinWidth="150" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Checkbox + status dot header cells (empty) -->
                                    <Border Grid.Column="0"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,1" />
                                    <Border Grid.Column="1"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,1" />

                                    <Border Grid.Column="2"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,1,1"
                                            Padding="8,6"
                                            Cursor="Hand" Background="Transparent">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding SortByNameCommand}" />
                                        </Border.InputBindings>
                                        <TextBlock FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}">
                                            <Run Text="File Name" /><Run Text="{Binding NameSortIndicator, Mode=OneWay}" />
                                        </TextBlock>
                                    </Border>

                                    <Border Grid.Column="3"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,1,1"
                                            Padding="8,6"
                                            Cursor="Hand" Background="Transparent">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding SortByDirectoryCommand}" />
                                        </Border.InputBindings>
                                        <TextBlock FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}">
                                            <Run Text="Directory" /><Run Text="{Binding DirectorySortIndicator, Mode=OneWay}" />
                                        </TextBlock>
                                    </Border>

                                    <Border Grid.Column="4"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="8,6"
                                            Cursor="Hand" Background="Transparent">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding SortBySizeCommand}" />
                                        </Border.InputBindings>
                                        <TextBlock FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Right">
                                            <Run Text="Size" /><Run Text="{Binding SizeSortIndicator, Mode=OneWay}" />
                                        </TextBlock>
                                    </Border>
                                </Grid>

                                <!-- Scrollable file list -->
                                <ScrollViewer x:Name="FileListScroll"
                                              Focusable="False"
                                              CanContentScroll="True"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </DockPanel>
                        </ControlTemplate>
                    </ListView.Template>

                    <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsIncluded}" Value="False">
                                        <Setter Property="Opacity" Value="0.4" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" MinWidth="120" />
                                        <ColumnDefinition Width="1.5*" MinWidth="150" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Include checkbox -->
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsIncluded}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center" />

                                    <!-- Status dot -->
                                    <Border Grid.Column="1"
                                            Background="Transparent"
                                            ToolTipService.InitialShowDelay="0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding BackupStatus}" Value="{x:Static vm:BackupStatus.BackedUp}">
                                                        <Setter Property="ToolTip" Value="Backed up" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding BackupStatus}" Value="{x:Static vm:BackupStatus.Changed}">
                                                        <Setter Property="ToolTip" Value="Changed since last backup" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding BackupStatus}" Value="{x:Static vm:BackupStatus.NotBackedUp}">
                                                        <Setter Property="ToolTip" Value="Not backed up" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Ellipse Width="7" Height="7"
                                                 VerticalAlignment="Center"
                                                 HorizontalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding BackupStatus}" Value="{x:Static vm:BackupStatus.BackedUp}">
                                                            <Setter Property="Fill" Value="#2E7D32" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding BackupStatus}" Value="{x:Static vm:BackupStatus.Changed}">
                                                            <Setter Property="Fill" Value="#EF6C00" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding BackupStatus}" Value="{x:Static vm:BackupStatus.NotBackedUp}">
                                                            <Setter Property="Fill" Value="#C62828" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Border>

                                    <Border Grid.Column="2"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,1,0"
                                            Padding="8,2">
                                        <TextBlock Text="{Binding FileName}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding FullPath}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <Border Grid.Column="3"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,1,0"
                                            Padding="8,2">
                                        <TextBlock Text="{Binding Directory}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Directory}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <TextBlock Grid.Column="4"
                                               Text="{Binding SizeText}"
                                               TextAlignment="Right"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12"
                                               Padding="8,2"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                <!-- ==================== DIRECTORY TREE ==================== -->
                <DockPanel Visibility="{Binding IsDirectoryMode, Converter={StaticResource BoolToVis}}">
                    <TreeView ItemsSource="{Binding Directories}"
                              BorderThickness="0"
                              Background="Transparent"
                              Padding="0"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">

                        <!-- Custom TreeView ControlTemplate: column headers + items in one shared-size scope -->
                        <TreeView.Template>
                            <ControlTemplate TargetType="TreeView">
                                <Border Grid.IsSharedSizeScope="True">
                                    <DockPanel>
                                        <!-- Column header row -->
                                        <Grid DockPanel.Dock="Top">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ComputedVerticalScrollBarVisibility, ElementName=DirTreeScroll}" Value="Visible">
                                                            <Setter Property="Margin" Value="0,0,17,0" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="DirCheckCol" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="DirFilterCol" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="DirFilesCol" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="DirSizeCol" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="0,0,1,1" />

                                            <Border Grid.Column="1"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="0,0,1,1" />

                                            <Border Grid.Column="2"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="0,0,1,1"
                                                    Padding="8,6">
                                                <TextBlock Text="Directory" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </Border>

                                            <Border Grid.Column="3"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="0,0,1,1"
                                                    Padding="8,6">
                                                <TextBlock Text="Files" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Right" />
                                            </Border>

                                            <Border Grid.Column="4"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="8,6">
                                                <TextBlock Text="Size" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Right" />
                                            </Border>
                                        </Grid>

                                        <!-- Scrollable tree items -->
                                        <ScrollViewer x:Name="DirTreeScroll"
                                                      Focusable="False"
                                                      CanContentScroll="False"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto"
                                                      Padding="0">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>
                            </ControlTemplate>
                        </TreeView.Template>

                        <!-- Custom TreeViewItem template: checkbox at fixed position, name indented -->
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <StackPanel>
                                                <!-- This node's row -->
                                                <Grid MinHeight="24">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="DirCheckCol" />
                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="DirFilterCol" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="DirFilesCol" />
                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="DirSizeCol" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Col 0: Checkbox + status dot (fixed position) -->
                                                    <Border Grid.Column="0"
                                                            BorderBrush="{StaticResource BorderBrush}"
                                                            BorderThickness="0,0,1,0">
                                                        <StackPanel Orientation="Horizontal"
                                                                    VerticalAlignment="Center" Margin="4,0">
                                                            <CheckBox IsChecked="{Binding IsIncluded}"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,0,4,0" />
                                                            <Border x:Name="StatusDotArea"
                                                                    Background="Transparent"
                                                                    Padding="3,0"
                                                                    VerticalAlignment="Center"
                                                                    ToolTipService.InitialShowDelay="0"
                                                                    Visibility="Collapsed">
                                                                <Ellipse x:Name="StatusDot"
                                                                         Width="7" Height="7" />
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Col 1: Filter button -->
                                                    <Border Grid.Column="1"
                                                            BorderBrush="{StaticResource BorderBrush}"
                                                            BorderThickness="0,0,1,0">
                                                        <Button Command="{Binding EditExclusionsCommand}"
                                                                Padding="3,1" Margin="2"
                                                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                Cursor="Hand"
                                                                Background="Transparent"
                                                                BorderBrush="{StaticResource BorderBrush}"
                                                                BorderThickness="1"
                                                                ToolTip="Edit exclusion/inclusion rules for this directory">
                                                            <TextBlock Text="Filter" FontSize="10"
                                                                       Foreground="{StaticResource TextDimBrush}" />
                                                        </Button>
                                                    </Border>

                                                    <!-- Col 2: Name area with tree indentation -->
                                                    <Border Grid.Column="2"
                                                            BorderBrush="{StaticResource BorderBrush}"
                                                            BorderThickness="0,0,1,0"
                                                            Background="Transparent">
                                                        <StackPanel Orientation="Horizontal"
                                                                    Margin="{Binding Depth, Converter={StaticResource DepthToIndent}}"
                                                                    VerticalAlignment="Center">
                                                            <!-- Expand arrow -->
                                                            <Border x:Name="ExpanderIcon"
                                                                    Width="16" Height="16" Margin="0,0,2,0">
                                                                <Path x:Name="Arrow"
                                                                      Data="M 4 2 L 12 6 L 4 10 Z"
                                                                      Fill="{StaticResource TextDimBrush}"
                                                                      VerticalAlignment="Center"
                                                                      HorizontalAlignment="Center"
                                                                      RenderTransformOrigin="0.5,0.5">
                                                                    <Path.RenderTransform>
                                                                        <RotateTransform Angle="0" />
                                                                    </Path.RenderTransform>
                                                                </Path>
                                                            </Border>
                                                            <!-- Name -->
                                                            <ContentPresenter x:Name="PART_Header"
                                                                              ContentSource="Header"
                                                                              VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Col 3: File count -->
                                                    <Border Grid.Column="3"
                                                            BorderBrush="{StaticResource BorderBrush}"
                                                            BorderThickness="0,0,1,0">
                                                        <TextBlock Text="{Binding FileCountText}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="11"
                                                                   HorizontalAlignment="Right"
                                                                   VerticalAlignment="Center"
                                                                   Padding="8,0"
                                                                   MinWidth="50" />
                                                    </Border>

                                                    <!-- Col 4: Size -->
                                                    <Border Grid.Column="4">
                                                        <TextBlock Text="{Binding SizeText}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="12"
                                                                   HorizontalAlignment="Right"
                                                                   VerticalAlignment="Center"
                                                                   Padding="8,0"
                                                                   MinWidth="60" />
                                                    </Border>
                                                </Grid>

                                                <!-- Children (full width — columns stay aligned) -->
                                                <ItemsPresenter x:Name="ItemsHost" Visibility="Collapsed" />
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsExpanded" Value="True">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                                    <Setter TargetName="Arrow" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="90" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="HasItems" Value="False">
                                                    <Setter TargetName="ExpanderIcon" Property="Visibility" Value="Hidden" />
                                                </Trigger>

                                                <!-- Excluded items -->
                                                <DataTrigger Binding="{Binding IsIncluded}" Value="False">
                                                    <Setter Property="Opacity" Value="0.4" />
                                                </DataTrigger>

                                                <!-- Backup status dot colors -->
                                                <DataTrigger Binding="{Binding BackupStatus}" Value="{x:Static vm:BackupStatus.BackedUp}">
                                                    <Setter TargetName="StatusDotArea" Property="Visibility" Value="Visible" />
                                                    <Setter TargetName="StatusDot" Property="Fill" Value="#2E7D32" />
                                                    <Setter TargetName="StatusDotArea" Property="ToolTip" Value="Backed up" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding BackupStatus}" Value="{x:Static vm:BackupStatus.Changed}">
                                                    <Setter TargetName="StatusDotArea" Property="Visibility" Value="Visible" />
                                                    <Setter TargetName="StatusDot" Property="Fill" Value="#EF6C00" />
                                                    <Setter TargetName="StatusDotArea" Property="ToolTip" Value="Changed since last backup" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding BackupStatus}" Value="{x:Static vm:BackupStatus.NotBackedUp}">
                                                    <Setter TargetName="StatusDotArea" Property="Visibility" Value="Visible" />
                                                    <Setter TargetName="StatusDot" Property="Fill" Value="#C62828" />
                                                    <Setter TargetName="StatusDotArea" Property="ToolTip" Value="Not backed up" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding BackupStatus}" Value="{x:Static vm:BackupStatus.Partial}">
                                                    <Setter TargetName="StatusDotArea" Property="Visibility" Value="Visible" />
                                                    <Setter TargetName="StatusDot" Property="Fill" Value="#F9A825" />
                                                    <Setter TargetName="StatusDotArea" Property="ToolTip" Value="Partially backed up" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.ItemContainerStyle>

                        <!-- Data template: just the name -->
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding FullPath}"
                                           VerticalAlignment="Center" />
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Grid>
        </Border>
    </DockPanel>
</UserControl>
