<Window x:Class="LithicBackup.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Lithic Backup"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource MainWindowStyle}">

    <StackPanel Margin="24">
        <TextBlock Text="Lithic Backup"
                   FontSize="22" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" />
        <TextBlock Text="{Binding Version}"
                   FontSize="13"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,4,0,0" />

        <TextBlock Text="Incremental disc backup with smart space management."
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="12" TextWrapping="Wrap"
                   Margin="0,16,0,0" />
        <TextBlock Text="Supports CD, DVD, Blu-Ray, and M-Disc media."
                   Foreground="{StaticResource TextDimBrush}"
                   FontSize="11" Margin="0,4,0,0" />

        <Border Height="1"
                Background="{StaticResource BorderBrush}"
                Margin="0,20,0,16" />

        <Button Content="OK" Padding="20,8"
                HorizontalAlignment="Right"
                Style="{StaticResource PrimaryButton}"
                IsDefault="True" IsCancel="True"
                Click="OK_Click" />
    </StackPanel>
</Window>
