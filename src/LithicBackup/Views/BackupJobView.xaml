<UserControl x:Class="LithicBackup.Views.BackupJobView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LithicBackup.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:BackupJobViewModel, IsDesignTimeCreatable=False}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Header -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Style="{StaticResource H2}" Text="Configure Backup" />
                <TextBlock Style="{StaticResource SubText}"
                           Text="Set your backup options, then plan and start the burn." />
            </StackPanel>

            <!-- Backup set name -->
            <TextBlock Text="Backup Set Name" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox Text="{Binding SetName, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6" Margin="0,0,0,16"
                     BorderBrush="{StaticResource BorderBrush}" />

            <!-- Target mode selector -->
            <Border Style="{StaticResource Card}" Padding="12">
                <StackPanel>
                    <TextBlock Text="Backup Target" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <RadioButton Content="Backup to Disc"
                                     IsChecked="True"
                                     GroupName="TargetMode"
                                     Margin="0,0,16,0"
                                     VerticalContentAlignment="Center"
                                     x:Name="DiscModeRadio" />
                        <RadioButton Content="Backup to Directory"
                                     IsChecked="{Binding IsDirectoryMode, Mode=TwoWay}"
                                     GroupName="TargetMode"
                                     VerticalContentAlignment="Center" />
                    </StackPanel>

                    <!-- Directory target path (visible only in directory mode) -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                Visibility="{Binding IsDirectoryMode, Converter={StaticResource BoolToVis}}">
                        <TextBox Text="{Binding TargetDirectoryPath, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" Width="400"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 ToolTip="Path to the backup target directory (e.g. E:\Backups\MySet)" />
                        <Button Content="Browse..." Command="{Binding BrowseTargetDirectoryCommand}"
                                Padding="12,6" Margin="8,0,0,0" Cursor="Hand" />
                    </StackPanel>

                    <!-- Subdirectory option (visible only in directory mode) -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                Visibility="{Binding IsDirectoryMode, Converter={StaticResource BoolToVis}}">
                        <CheckBox Content="Create subdirectory:"
                                  IsChecked="{Binding CreateSubdirectory, Mode=TwoWay}"
                                  VerticalContentAlignment="Center"
                                  Margin="0,0,8,0" />
                        <TextBox Text="{Binding SubdirectoryName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" Width="250"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 IsEnabled="{Binding CreateSubdirectory}"
                                 ToolTip="Name of the subdirectory to create under the target directory" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Media info (disc mode only) -->
            <Border Style="{StaticResource Card}" Padding="12"
                    Visibility="{Binding IsDirectoryMode, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                <StackPanel>
                    <TextBlock Text="Disc Media" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding MediaInfoText}"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Options -->
            <TextBlock Text="Options" FontWeight="SemiBold" Margin="0,0,0,8" />

            <!-- Excluded file patterns (both modes) -->
            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="Exclude file paths matching these patterns (one per line):"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,0,0,4" />
                <TextBox Text="{Binding ExcludedExtensions, UpdateSourceTrigger=PropertyChanged}"
                         Padding="6,4" Height="52"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         BorderBrush="{StaticResource BorderBrush}"
                         ToolTip="Examples:  *.log  *.tmp  *.bak  */.vs/*  */bin/*  */obj/*&#x0a;&#x0a;Use * to match any characters in a file name.&#x0a;Use */ to match directory paths." />
            </StackPanel>

            <!-- Disc-specific options (hidden in directory mode) -->
            <Grid Margin="0,0,0,16"
                  Visibility="{Binding IsDirectoryMode, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Zip mode -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Zip Mode"
                           VerticalAlignment="Center" Margin="0,0,0,8" />
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding ZipModeOptions}"
                          SelectedItem="{Binding ZipMode}"
                          Padding="6,4" Margin="0,0,0,8" />

                <!-- Filesystem -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Filesystem"
                           VerticalAlignment="Center" Margin="0,0,0,8" />
                <ComboBox Grid.Row="1" Grid.Column="1"
                          ItemsSource="{Binding FilesystemTypeOptions}"
                          SelectedItem="{Binding FilesystemType}"
                          Padding="6,4" Margin="0,0,0,8" />

                <!-- Capacity override -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Capacity Override (GB)"
                           VerticalAlignment="Center" Margin="0,0,0,8" />
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding CapacityOverrideGb, UpdateSourceTrigger=PropertyChanged}"
                         Padding="6,4" Margin="0,0,0,8"
                         BorderBrush="{StaticResource BorderBrush}"
                         ToolTip="Enter disc capacity in GB (e.g. 22.5) or leave blank for auto-detect" />

                <!-- Checkboxes -->
                <CheckBox Grid.Row="3" Grid.Column="0"
                          Content="Verify after burn"
                          IsChecked="{Binding VerifyAfterBurn}"
                          Margin="0,0,0,6" />

                <CheckBox Grid.Row="3" Grid.Column="1"
                          Content="Include catalog on disc"
                          IsChecked="{Binding IncludeCatalogOnDisc}"
                          Margin="0,0,0,6" />

                <CheckBox Grid.Row="4" Grid.Column="0"
                          Content="Allow file splitting across discs"
                          IsChecked="{Binding AllowFileSplitting}"
                          Margin="0,0,0,6" />
            </Grid>

            <!-- Directory-specific options (visible only in directory mode) -->
            <Border Style="{StaticResource Card}" Padding="12"
                    Visibility="{Binding IsDirectoryMode, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <CheckBox Content="Verify backup after completion"
                              IsChecked="{Binding VerifyAfterBackup}"
                              Margin="0,0,0,10" />

                    <TextBlock Text="Deduplication" FontWeight="SemiBold" Margin="0,0,0,8" />

                    <CheckBox Content="File-level deduplication (identical files stored once)"
                              IsChecked="{Binding EnableFileDeduplication}"
                              Margin="0,0,0,6" />

                    <CheckBox Content="Block-level deduplication (detect partial file similarity)"
                              IsChecked="{Binding EnableDeduplication}"
                              Margin="0,0,0,6" />

                    <StackPanel Orientation="Horizontal" Margin="20,0,0,8"
                                IsEnabled="{Binding EnableDeduplication}">
                        <TextBlock Text="Block size (KB):" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Text="{Binding DeduplicationBlockSizeKb, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4" Width="80"
                                 BorderBrush="{StaticResource BorderBrush}" />
                    </StackPanel>

                    <TextBlock Text="Version Retention Tier Sets" FontWeight="SemiBold" Margin="0,8,0,4" />
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,8"
                               Text="Version retention policies defined in the source selection. Edit them there." />

                    <ItemsControl ItemsSource="{Binding TierSets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,0,2" FontSize="11">
                                    <Run Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold" />
                                    <Run Text=" — " Foreground="{StaticResource TextDimBrush}" />
                                    <Run Text="{Binding Tiers.Count, Mode=OneWay, StringFormat='{}{0} tier(s)'}"
                                         Foreground="{StaticResource TextSecondaryBrush}" />
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Plan summary -->
            <Border Style="{StaticResource Card}" Padding="12">
                <StackPanel>
                    <TextBlock Text="Backup Plan" FontWeight="SemiBold" Margin="0,0,0,4" />

                    <!-- Planning spinner -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsPlanning, Converter={StaticResource BoolToVis}}">
                        <ProgressBar IsIndeterminate="True" Width="100" Height="14" Margin="0,0,8,0" />
                        <TextBlock Text="Scanning..." Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <TextBlock Text="{Binding PlanSummary}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Visibility="{Binding IsPlanning, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                </StackPanel>
            </Border>

            <!-- Bottom buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Back" Command="{Binding BackCommand}"
                        Padding="16,8" Margin="0,0,8,0" Cursor="Hand" />
                <Button Content="Plan Backup" Command="{Binding PlanCommand}"
                        Margin="0,0,8,0"
                        ToolTipService.ShowOnDisabled="True"
                        ToolTipService.InitialShowDelay="0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="ToolTip"
                                            Value="Planning is already in progress." />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Start Backup" Command="{Binding StartCommand}"
                        ToolTipService.ShowOnDisabled="True"
                        ToolTipService.InitialShowDelay="0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="ToolTip"
                                            Value="Click &quot;Plan Backup&quot; first to generate a backup plan." />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
            </StackPanel>
        </ScrollViewer>
</UserControl>
