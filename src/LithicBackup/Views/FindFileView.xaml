<UserControl x:Class="LithicBackup.Views.FindFileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LithicBackup.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:FindFileViewModel, IsDesignTimeCreatable=False}">

    <DockPanel Margin="8">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource H2}" Text="Find File or Directory" />
            <TextBlock Style="{StaticResource SubText}"
                       Text="Search for files or directories across all backup sets." />
        </StackPanel>

        <!-- Search bar -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4" Margin="0,0,8,0"
                     ToolTip="Enter a file name, extension, or path fragment (e.g. .docx, report, photos\vacation)">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding SearchCommand}" />
                </TextBox.InputBindings>
            </TextBox>
            <Button Grid.Column="1"
                    Style="{StaticResource PrimaryButton}"
                    Content="Search"
                    Command="{Binding SearchCommand}"
                    Padding="16,6" />
        </Grid>

        <!-- Status text -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding StatusText}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,8" />

        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Command="{Binding CloseCommand}"
                    Padding="16,8" Cursor="Hand" />
        </StackPanel>

        <!-- Results list -->
        <Border BorderThickness="1"
                BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource SurfaceBrush}"
                Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <!-- Column header row -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="8,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="70" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Backup Set"
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="Files"
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right" />
                        <TextBlock Grid.Column="2" Text="Total Size"
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right" />
                        <TextBlock Grid.Column="3" Text="Ver."
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right" />
                        <TextBlock Grid.Column="4" Text="Last Backed Up"
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right" />
                    </Grid>
                </Border>

                <!-- Items -->
                <ListView ItemsSource="{Binding Results}"
                          BorderThickness="0"
                          Background="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="8,6" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding BackupSetName}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           ToolTip="{Binding BackupSetName}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding MatchingFileCount, StringFormat=N0}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding TotalSizeText}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Grid.Column="3"
                                           Text="{Binding LatestVersion}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Grid.Column="4"
                                           Text="{Binding LastBackedUpText}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" />
                                <Button Grid.Column="5"
                                        Content="Restore"
                                        Padding="8,2" Margin="6,0,0,0"
                                        Cursor="Hand" FontSize="11"
                                        Command="{Binding DataContext.RestoreFromSetCommand,
                                                  RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding BackupSetId}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>
        </Border>
    </DockPanel>
</UserControl>
