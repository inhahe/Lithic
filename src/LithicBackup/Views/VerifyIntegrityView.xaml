<UserControl x:Class="LithicBackup.Views.VerifyIntegrityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LithicBackup.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:VerifyIntegrityViewModel, IsDesignTimeCreatable=False}">

    <DockPanel Margin="8">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource H2}" Text="Verify Integrity" />
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,2,0,0">
                <Run Text="Backup set: " />
                <Run Text="{Binding BackupSetName, Mode=OneWay}"
                     FontWeight="SemiBold" />
            </TextBlock>
        </StackPanel>

        <!-- Loading / progress indicator -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="{Binding IsProgressIndeterminate}"
                         Minimum="0" Maximum="100"
                         Value="{Binding ProgressPercent, Mode=OneWay}"
                         Height="4" Margin="0,0,0,8"
                         Foreground="{StaticResource PrimaryBrush}" />
            <TextBlock Text="{Binding ProgressText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       FontSize="12" />
        </StackPanel>

        <!-- Bottom bar: verify options on the left, actions on the right -->
        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <!-- Verify options (left) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                <CheckBox Content="Verify file contents (read &amp; re-hash)"
                          IsChecked="{Binding VerifyContents}"
                          IsEnabled="{Binding CanVerify}"
                          VerticalAlignment="Center" Cursor="Hand"
                          ToolTip="When checked, every stored file and block is read back and its SHA-256 is re-computed to detect silent corruption / bit-rot. Slower — reads the whole backup. When unchecked, only existence (including block-file location) is checked." />
                <Button Content="Verify" Command="{Binding VerifyCommand}"
                        Padding="16,8" Margin="12,0,0,0" Cursor="Hand"
                        ToolTip="Run verification with the current option." />
            </StackPanel>

            <!-- Actions (right) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{Binding RepairableCount}"
                        ContentStringFormat="Re-backup {0:N0} missing file(s)"
                        Command="{Binding RepairCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Visibility="{Binding HasRepairable, Converter={StaticResource BoolToVis}}"
                        Padding="16,8" Margin="0,0,8,0" Cursor="Hand"
                        ToolTip="Flag the files whose backed-up copy is missing so the next Backup re-copies them to the destination." />
                <Button Content="Close" Command="{Binding CloseCommand}"
                        Padding="16,8" Cursor="Hand" />
            </StackPanel>
        </Grid>

        <!-- Results (hidden while loading) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel>
                <!-- Stats grid -->
                <Border Style="{StaticResource Card}" Padding="16,12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Source files -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="Source Files"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding SourceFilesChecked, StringFormat=N0}"
                                       FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Backed-up files -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="Files Checked"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding RecordsChecked, StringFormat=N0}"
                                       FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- References -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="References"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding FileRefsChecked, StringFormat=N0}"
                                       FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Issues -->
                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                            <TextBlock Text="Issues"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding IssueCount, StringFormat=N0}"
                                       FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#C62828" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Succeeded}" Value="True">
                                                <Setter Property="Foreground" Value="#2E7D32" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Summary text -->
                <TextBlock Text="{Binding SummaryText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <!-- Issues list -->
                <Expander Header="{Binding IssueCount, StringFormat='Issues ({0:N0})'}"
                          IsExpanded="True"
                          Visibility="{Binding HasIssues, Converter={StaticResource BoolToVis}}">
                    <Border BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource SurfaceBrush}"
                            MaxHeight="380">
                        <ListView ItemsSource="{Binding Issues}"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="8,3" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Kind}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#C62828"
                                                   FontSize="11" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Path}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Path}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="11" />
                                            <TextBlock Text="{Binding Detail}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="10" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
