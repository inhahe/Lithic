<UserControl x:Class="LithicBackup.Views.BackupCoverageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LithicBackup.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:BackupCoverageViewModel, IsDesignTimeCreatable=False}">

    <DockPanel Margin="8">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource H2}" Text="Backup Coverage" />
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,2,0,0">
                <Run Text="Backup set: " />
                <Run Text="{Binding BackupSetName, Mode=OneWay}"
                     FontWeight="SemiBold" />
            </TextBlock>
        </StackPanel>

        <!-- Loading indicator -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="{Binding IsProgressIndeterminate}"
                         Minimum="0" Maximum="100"
                         Value="{Binding ScanPercent, Mode=OneWay}"
                         Height="4" Margin="0,0,0,8"
                         Foreground="{StaticResource PrimaryBrush}" />
            <TextBlock Text="{Binding ScanProgressText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" />
        </StackPanel>

        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Command="{Binding CloseCommand}"
                    Padding="16,8" Cursor="Hand" />
        </StackPanel>

        <!-- Results (hidden while loading) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel>
                <!-- Coverage progress bar -->
                <Grid Margin="0,0,0,16">
                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{Binding CoveragePercent, Mode=OneWay}"
                                 Height="24"
                                 Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" FontSize="12">
                        <TextBlock.Text>
                            <Binding Path="CoveragePercent" StringFormat="{}{0:F1}% backed up" />
                        </TextBlock.Text>
                    </TextBlock>
                </Grid>

                <!-- Stats grid -->
                <Border Style="{StaticResource Card}" Padding="16,12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Total -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="Total Source"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding TotalSourceFiles, StringFormat=N0}"
                                       FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding TotalSourceSizeText}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Backed Up -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="Backed Up"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding BackedUpCount, StringFormat=N0}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="#2E7D32"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding BackedUpSizeText}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Not Backed Up -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="Not Backed Up"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding NotBackedUpCount, StringFormat=N0}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="#C62828"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding NotBackedUpSizeText}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Changed -->
                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                            <TextBlock Text="Changed"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding ChangedCount, StringFormat=N0}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="#EF6C00"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding ChangedSizeText}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Summary text -->
                <TextBlock Text="{Binding SummaryText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <!-- Not backed up files list -->
                <Expander Header="{Binding NotBackedUpCount, StringFormat='Not backed up ({0:N0})'}"
                          IsExpanded="False"
                          Margin="0,0,0,8"
                          Visibility="{Binding HasNotBackedUp, Converter={StaticResource BoolToVis}}">
                    <Border BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource SurfaceBrush}"
                            MaxHeight="250">
                        <ListView ItemsSource="{Binding NotBackedUpFiles}"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="8,3" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding FilePath}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding FilePath}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="11" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SizeText}"
                                                   TextAlignment="Right"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Expander>

                <!-- Changed files list -->
                <Expander Header="{Binding ChangedCount, StringFormat='Changed since last backup ({0:N0})'}"
                          IsExpanded="False"
                          Visibility="{Binding HasChanged, Converter={StaticResource BoolToVis}}">
                    <Border BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource SurfaceBrush}"
                            MaxHeight="250">
                        <ListView ItemsSource="{Binding ChangedFiles}"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="8,3" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding FilePath}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding FilePath}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="11" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SizeText}"
                                                   TextAlignment="Right"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
