<UserControl x:Class="LithicBackup.Views.BurnProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LithicBackup.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:BurnProgressViewModel, IsDesignTimeCreatable=False}">

    <StackPanel Margin="8">
        <!-- Header -->
        <TextBlock Style="{StaticResource H2}" Text="{Binding StatusText}" Margin="0,0,0,16" />

        <!-- Disc progress (hidden in directory mode) -->
        <Grid Margin="0,0,0,12"
              Visibility="{Binding IsDirectoryMode, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Foreground="{StaticResource TextSecondaryBrush}">
                <TextBlock.Text>
                    <MultiBinding StringFormat="Disc {0} of {1}">
                        <Binding Path="CurrentDisc" />
                        <Binding Path="TotalDiscs" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>

            <ProgressBar Grid.Column="1"
                         Minimum="0" Maximum="100"
                         Value="{Binding DiscPercentage, Mode=OneWay}"
                         Height="20"
                         Foreground="{StaticResource PrimaryBrush}" />
        </Grid>

        <!-- Overall progress -->
        <TextBlock Style="{StaticResource SubText}" Text="Overall Progress" Margin="0,0,0,4" />
        <ProgressBar Minimum="0" Maximum="100"
                     Value="{Binding OverallPercentage, Mode=OneWay}"
                     Height="20" Margin="0,0,0,12"
                     Foreground="{StaticResource AccentBrush}" />

        <!-- Stats -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource SubText}" Text="Written" />
                <TextBlock Text="{Binding BytesWrittenText}"
                           FontSize="14" FontWeight="SemiBold" />
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                <TextBlock Style="{StaticResource SubText}" Text="Elapsed" />
                <TextBlock Text="{Binding ElapsedText}"
                           FontSize="14" FontWeight="SemiBold" />
            </StackPanel>

            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                <TextBlock Style="{StaticResource SubText}" Text="Remaining" />
                <TextBlock Text="{Binding RemainingText}"
                           FontSize="14" FontWeight="SemiBold" />
            </StackPanel>
        </Grid>

        <!-- Current file -->
        <TextBlock Style="{StaticResource SubText}" Text="Current:" Margin="0,0,0,2" />
        <TextBlock Text="{Binding CurrentFile}"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,0,0,4" />

        <!-- Per-file progress (visible when a file is actively being copied) -->
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressBar Grid.Column="0"
                         Minimum="0" Maximum="100"
                         Value="{Binding CurrentFilePercentage, Mode=OneWay}"
                         Height="14"
                         Foreground="{StaticResource PrimaryBrush}" />

            <TextBlock Grid.Column="1"
                       Text="{Binding CurrentFileSizeText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0" />
        </Grid>

        <!-- Result detail (shown after completion) -->
        <TextBlock Text="{Binding ResultDetail}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   TextWrapping="Wrap"
                   Visibility="{Binding IsComplete, Converter={StaticResource BoolToVis}}"
                   Margin="0,0,0,8" />

        <!-- Failed/skipped files list (scrollable, shown after completion when there are failures) -->
        <Border Visibility="{Binding HasFailedFiles, Converter={StaticResource BoolToVis}}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="4"
                Margin="0,0,0,16"
                MaxHeight="200">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="8,6,8,4">
                    <TextBlock FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}">
                        <Run Text="Failed/skipped files: " />
                        <Run Text="{Binding FailedFiles.Count, Mode=OneWay}" />
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Copy to Clipboard"
                                Command="{Binding CopyFailedFilesCommand}"
                                Padding="8,2" Margin="0,0,6,0" Cursor="Hand"
                                FontSize="11" />
                        <Button Content="Export..."
                                Command="{Binding ExportFailedFilesCommand}"
                                Padding="8,2" Cursor="Hand"
                                FontSize="11" />
                    </StackPanel>
                </DockPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding FailedFiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,1,0,0"
                                        Padding="8,4">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding ActionTaken}"
                                                   Foreground="{StaticResource TextDimBrush}"
                                                   FontSize="10"
                                                   VerticalAlignment="Top"
                                                   Margin="8,0,0,0" />
                                        <StackPanel>
                                            <TextBlock Text="{Binding Path}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Path}" />
                                            <TextBlock Text="{Binding Error}"
                                                       Foreground="#FFCC4444"
                                                       FontSize="11"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal">
            <!-- Pause/Resume (directory backups only) -->
            <Button Content="{Binding PauseResumeLabel}"
                    Command="{Binding PauseResumeCommand}"
                    Padding="16,8" Cursor="Hand"
                    Margin="0,0,8,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBurning}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsDirectoryMode}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Style="{StaticResource PrimaryButton}"
                    Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Visibility="{Binding IsBurning, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,8,0" />
            <Button Style="{StaticResource PrimaryButton}"
                    Content="Done"
                    Command="{Binding DoneCommand}"
                    Visibility="{Binding IsComplete, Converter={StaticResource BoolToVis}}" />
        </StackPanel>
    </StackPanel>
</UserControl>
