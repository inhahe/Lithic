<UserControl x:Class="LithicBackup.Views.CatalogFreeRestoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LithicBackup.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CatalogFreeRestoreViewModel, IsDesignTimeCreatable=False}">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource H2}" Text="Restore Without Catalog" />
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,2,0,0"
                       TextWrapping="Wrap"
                       Text="Disaster recovery: rebuild your files straight from a backup folder when the backup catalog has been lost. Picks no backup set — it reads the destination tree directly, reassembling deduplicated and referenced files." />
        </StackPanel>

        <!-- Backup folder -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Backup folder"
                       FontWeight="SemiBold" FontSize="12" Margin="0,0,0,2" />
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding BackupPath, UpdateSourceTrigger=PropertyChanged}"
                         Padding="6,4" Margin="0,0,8,0" />
                <Button Grid.Column="1" Content="Browse..."
                        Command="{Binding BrowseBackupCommand}"
                        Padding="12,4" />
            </Grid>
        </Grid>

        <!-- Output folder -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Output folder"
                       FontWeight="SemiBold" FontSize="12" Margin="0,0,0,2" />
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                         Padding="6,4" Margin="0,0,8,0" />
                <Button Grid.Column="1" Content="Browse..."
                        Command="{Binding BrowseOutputCommand}"
                        Padding="12,4" />
            </Grid>
        </Grid>

        <!-- Status / result area (fills remaining space) -->
        <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold"
                           TextWrapping="Wrap" Margin="0,0,0,4" />
                <TextBlock Text="{Binding ResultDetail}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Visibility="{Binding IsComplete, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
        </Border>

        <!-- Progress area -->
        <StackPanel Grid.Row="4" Margin="0,0,0,12"
                    Visibility="{Binding IsRestoring, Converter={StaticResource BoolToVis}}">
            <ProgressBar Minimum="0" Maximum="100"
                         Value="{Binding RestorePercentage, Mode=OneWay}"
                         Height="20" Margin="0,0,0,4"
                         Foreground="{StaticResource PrimaryBrush}" />
            <TextBlock Style="{StaticResource SubText}" Text="{Binding ProgressText}" />
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding CurrentFile}" />
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal">
            <Button Style="{StaticResource PrimaryButton}"
                    Content="Restore"
                    Command="{Binding RestoreCommand}"
                    Margin="0,0,8,0" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Padding="16,8" Margin="0,0,8,0"
                    Visibility="{Binding IsRestoring, Converter={StaticResource BoolToVis}}" />
            <Button Content="Done"
                    Command="{Binding DoneCommand}"
                    Padding="16,8" Cursor="Hand" />
        </StackPanel>
    </Grid>
</UserControl>
