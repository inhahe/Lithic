<UserControl x:Class="LithicBackup.Views.CatalogFreeRestoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LithicBackup.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CatalogFreeRestoreViewModel, IsDesignTimeCreatable=False}">

    <!--
        DockPanel (not a Grid) so the button bar — which holds the only way out of
        this view ("Done") — is docked to the bottom and can never be clipped off
        screen on a short window. Only the status/result area (which scrolls
        internally) yields space; the exit bar always stays visible.
    -->
    <DockPanel Margin="8" LastChildFill="True">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource H2}" Text="Restore Without Catalog" />
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,2,0,0"
                       TextWrapping="Wrap"
                       Text="Disaster recovery: rebuild your files straight from a backup folder when the backup catalog has been lost. Picks no backup set — it reads the destination tree directly, reassembling deduplicated and referenced files." />
        </StackPanel>

        <!-- Backup folder -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Backup folder"
                       FontWeight="SemiBold" FontSize="12" Margin="0,0,0,2" />
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding BackupPath, UpdateSourceTrigger=PropertyChanged}"
                         Padding="6,4" Margin="0,0,8,0" />
                <Button Grid.Column="1" Content="Browse..."
                        Command="{Binding BrowseBackupCommand}"
                        Padding="12,4" />
            </Grid>
        </Grid>

        <!-- Output folder -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Output folder"
                       FontWeight="SemiBold" FontSize="12" Margin="0,0,0,2" />
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                         Padding="6,4" Margin="0,0,8,0" />
                <Button Grid.Column="1" Content="Browse..."
                        Command="{Binding BrowseOutputCommand}"
                        Padding="12,4" />
            </Grid>
        </Grid>

        <!-- Buttons (docked to the bottom so the exit is always reachable) -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,12,0,0" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Restore"
                            Command="{Binding RestoreCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Padding="16,8"
                            Visibility="{Binding IsRestoring, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <Button Grid.Column="2" Content="Done"
                        Command="{Binding DoneCommand}"
                        Padding="24,8" Cursor="Hand"
                        ToolTip="Close this view and return to the backup sets." />
            </Grid>
        </Border>

        <!-- Progress area (docked above the buttons while restoring) -->
        <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,12"
                    Visibility="{Binding IsRestoring, Converter={StaticResource BoolToVis}}">
            <ProgressBar Minimum="0" Maximum="100"
                         Value="{Binding RestorePercentage, Mode=OneWay}"
                         Height="20" Margin="0,0,0,4"
                         Foreground="{StaticResource PrimaryBrush}" />
            <TextBlock Style="{StaticResource SubText}" Text="{Binding ProgressText}" />
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding CurrentFile}" />
        </StackPanel>

        <!-- Status / result area (fills remaining space) -->
        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Padding="12" Margin="0,0,0,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold"
                               TextWrapping="Wrap" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding ResultDetail}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Visibility="{Binding IsComplete, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </DockPanel>
</UserControl>
