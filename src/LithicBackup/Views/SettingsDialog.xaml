<Window x:Class="LithicBackup.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="580" SizeToContent="Height"
        MaxHeight="1100"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource MainWindowStyle}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl x:Name="SettingsTabs" Grid.Row="0">

            <!-- ================= General ================= -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="1000">
                    <StackPanel Margin="0,0,4,0">
                        <TextBlock Text="Preferences"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,12" />

                        <CheckBox Content="Don't suggest running a backup after file changes accumulate"
                                  IsChecked="{Binding SuppressBackupSuggestions}"
                                  Margin="0,0,0,4" />

                        <CheckBox Content="Check for updates on startup"
                                  IsChecked="{Binding CheckForUpdates}"
                                  Margin="0,8,0,4" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ================= Memory ================= -->
            <TabItem Header="Memory">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="1000">
                    <StackPanel Margin="0,0,4,0">
                        <TextBlock Text="Memory budget"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="How much RAM a backup may use to buffer file contents in memory, so each file is read from disk only once for both deduplication analysis and writing. Larger budgets speed up backups; leaving headroom keeps other programs responsive."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Margin="0,4,0,16" />

                        <!-- Auto mode -->
                        <RadioButton x:Name="AutoRadio" GroupName="MemMode"
                                     Content="Automatic"
                                     IsChecked="{Binding IsAuto}"
                                     Margin="0,0,0,8" />
                        <Grid Margin="24,0,0,12" IsEnabled="{Binding IsAuto}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Use up to" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" Margin="0,0,8,6" />
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Text="{Binding PercentOfTotal, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="6,4" Margin="0,0,8,6"
                                     BorderBrush="{StaticResource BorderBrush}" />
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="% of total RAM" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" Margin="0,0,0,6" />

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Keep free" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" Margin="0,0,8,0" />
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Text="{Binding ReserveGb, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="6,4" Margin="0,0,8,0"
                                     BorderBrush="{StaticResource BorderBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="2"
                                       Text="GB of available RAM for other programs" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" />
                        </Grid>

                        <!-- Fixed mode -->
                        <RadioButton x:Name="FixedRadio" GroupName="MemMode"
                                     Content="Fixed amount"
                                     IsChecked="{Binding IsFixed}"
                                     Margin="0,0,0,8" />
                        <Grid Margin="24,0,0,12" IsEnabled="{Binding IsFixed}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Use up to" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" Margin="0,0,8,0" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding FixedGb, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="6,4" Margin="0,0,8,0"
                                     BorderBrush="{StaticResource BorderBrush}" />
                            <TextBlock Grid.Column="2"
                                       Text="GB" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" />
                        </Grid>

                        <Border Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="12,10" Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding SystemMemoryText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ComputedBudgetText}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="12" FontWeight="SemiBold"
                                           TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ================= Editing ================= -->
            <TabItem Header="Editing">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="1000">
                    <StackPanel Margin="0,0,4,0">
                        <TextBlock Text="After editing a set's folders"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="When you save a change to which folders a set backs up, the app can scan the affected folders to back up ones you added and remove copies of ones you dropped. (Merely browsing/expanding the tree never triggers a scan.)"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Margin="0,4,0,12" />

                        <RadioButton GroupName="ReconcileMode"
                                     Content="Ask each time (recommended)"
                                     IsChecked="{Binding ReconcileAsk}"
                                     Margin="0,0,0,4" />
                        <RadioButton GroupName="ReconcileMode"
                                     Content="Always scan and sync automatically"
                                     IsChecked="{Binding ReconcileAlways}"
                                     Margin="0,4,0,4" />
                        <RadioButton GroupName="ReconcileMode"
                                     Content="Never — sync on the next full backup instead"
                                     IsChecked="{Binding ReconcileNever}"
                                     Margin="0,4,0,4" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ================= Disc ================= -->
            <TabItem Header="Disc">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="1000">
                    <StackPanel Margin="0,0,4,0">
                        <TextBlock Text="Disc staging"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="How files are supplied to the burner when backing up to disc."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Margin="0,4,0,12" />

                        <RadioButton x:Name="CopyToTempRadio" GroupName="StagingMode"
                                     IsChecked="{Binding StageToTemp}"
                                     Margin="0,0,0,4">
                            <StackPanel>
                                <TextBlock Text="Copy to a temporary folder first (recommended)"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" />
                                <TextBlock Text="Safest, but needs enough free temp space to hold a full disc's worth of data (up to ~100 GB for Blu-ray). Source files are only locked briefly while copied."
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="BurnInPlaceRadio" GroupName="StagingMode"
                                     IsChecked="{Binding BurnInPlace}"
                                     Margin="0,8,0,4">
                            <StackPanel>
                                <TextBlock Text="Burn directly from the source (no temporary copy)"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" />
                                <TextBlock Text="Avoids needing temp space for large media, but locks each source file for the whole burn so nothing else can modify it. Zipped and split files still use a temporary copy."
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ================= Continuous ================= -->
            <TabItem Header="Continuous">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="1000">
                    <StackPanel Margin="0,0,4,0">
                        <TextBlock Text="Continuous backup rules"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="How continuous mode decides when a changed file is ready to copy. These rules are global — they apply to every set that backs up continuously."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Margin="0,4,0,16" />

                        <!-- ===== Debounce (settle time by size) ===== -->
                        <TextBlock Text="Settle time (by file size)"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="A changed file is copied once it has stayed unchanged this long. Larger files get a longer settle time, so a brief pause mid-write (e.g. during a big download) doesn't kick off a wasteful copy. Each file uses the first tier its size fits under, smallest first."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Margin="0,4,0,8" />

                        <!-- header row -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="28" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Files up to"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                            <TextBlock Grid.Column="2" Text="Settle"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding DebounceRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="28" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding SizeText, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="6,4" VerticalContentAlignment="Center"
                                                 BorderBrush="{StaticResource BorderBrush}" />
                                        <TextBlock Grid.Column="1" Text="→"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding DebounceText, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="6,4" VerticalContentAlignment="Center"
                                                 BorderBrush="{StaticResource BorderBrush}" />
                                        <TextBlock Grid.Column="3" Text="seconds"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                        <Button Grid.Column="4" Content="✕"
                                                Style="{StaticResource LinkButton}"
                                                ToolTip="Remove this tier"
                                                HorizontalAlignment="Center"
                                                Click="RemoveDebounceRow_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="+ Add size tier"
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Left"
                                Click="AddDebounceRow_Click" />
                        <TextBlock Text="Leave “Files up to” blank on the last tier so it applies to everything larger. Sizes accept units like KB, MB, GB."
                                   Foreground="{StaticResource TextDimBrush}"
                                   FontSize="11" TextWrapping="Wrap" FontStyle="Italic"
                                   Margin="0,4,0,0" />

                        <Border Height="1" Background="{StaticResource BorderBrush}"
                                Margin="0,20,0,16" />

                        <!-- ===== Max wait (by name/path mask) ===== -->
                        <TextBlock Text="Maximum wait (by name / path)"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Some files change constantly and never settle (busy logs, append-only session files), so the settle time above never fires. For files matching these masks, back them up anyway after this long — even mid-write — because their partial contents are still meaningful. Files matching no tier are only copied once they settle (never forced mid-write), the safe choice for downloads and databases whose partial contents would be corrupt."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Margin="0,4,0,8" />

                        <!-- header row -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="28" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Name"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                            <TextBlock Grid.Column="1" Text="Include masks"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                            <TextBlock Grid.Column="2" Text="Exclude masks"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                            <TextBlock Grid.Column="3" Text="Max wait"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding MaxWaitRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="28" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Margin="0,0,6,0"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="6,4" VerticalContentAlignment="Center"
                                                 BorderBrush="{StaticResource BorderBrush}" />
                                        <TextBox Grid.Column="1" Margin="0,0,6,0"
                                                 Text="{Binding IncludeText, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="6,4" VerticalContentAlignment="Center"
                                                 BorderBrush="{StaticResource BorderBrush}" />
                                        <TextBox Grid.Column="2" Margin="0,0,6,0"
                                                 Text="{Binding ExcludeText, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="6,4" VerticalContentAlignment="Center"
                                                 BorderBrush="{StaticResource BorderBrush}" />
                                        <TextBox Grid.Column="3"
                                                 Text="{Binding MaxWaitText, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="6,4" VerticalContentAlignment="Center"
                                                 BorderBrush="{StaticResource BorderBrush}" />
                                        <Button Grid.Column="4" Content="✕"
                                                Style="{StaticResource LinkButton}"
                                                ToolTip="Remove this tier"
                                                HorizontalAlignment="Center"
                                                Click="RemoveMaxWaitRow_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="+ Add mask tier"
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Left"
                                Click="AddMaxWaitRow_Click" />
                        <TextBlock Text="Masks use * and ? (e.g. *.log). Separate multiple with commas. Max wait is in seconds; leave blank or 0 for no limit (settle only)."
                                   Foreground="{StaticResource TextDimBrush}"
                                   FontSize="11" TextWrapping="Wrap" FontStyle="Italic"
                                   Margin="0,4,0,0" />

                        <Button Content="Restore default rules"
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Left"
                                Margin="0,16,0,0"
                                Click="RestoreContinuousDefaults_Click" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Buttons (shared across tabs) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Cancel" Padding="16,8" Margin="0,0,8,0"
                    Cursor="Hand" IsCancel="True"
                    Click="Cancel_Click" />
            <Button Style="{StaticResource PrimaryButton}"
                    Content="Save" Padding="16,8"
                    Cursor="Hand" IsDefault="True"
                    Click="OK_Click" />
        </StackPanel>
    </Grid>
</Window>
