<Window x:Class="LithicBackup.Views.ReviewTreeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LithicBackup.ViewModels"
        xmlns:b="clr-namespace:LithicBackup.Behaviors"
        Title="{Binding WindowTitle}"
        Width="640" Height="500"
        MinWidth="480" MinHeight="340"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Style="{StaticResource MainWindowStyle}">

    <Window.Resources>
        <!-- ===========================================================
             Read-only review row: a 3-column Grid (Name / Files / Size)
             whose columns share a SharedSizeGroup so every row aligns with
             the header regardless of nesting depth.  No checkbox column —
             both previews are all-or-nothing.  Indent affects only the
             name column's content (per-node Depth via DepthToIndent).
             ============================================================ -->
        <Style x:Key="ReviewTreeViewItem" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Grid MinHeight="22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" MinWidth="64" SharedSizeGroup="ReviewFilesCol" />
                                    <ColumnDefinition Width="Auto" MinWidth="96" SharedSizeGroup="ReviewSizeCol" />
                                </Grid.ColumnDefinitions>

                                <!-- Col 0: Name (indented per Depth, with expand arrow) -->
                                <Border x:Name="NameArea" Grid.Column="0"
                                        Background="Transparent"
                                        Padding="0,1,0,1">
                                    <StackPanel Orientation="Horizontal"
                                                Margin="{Binding Depth, Converter={StaticResource DepthToIndent}}"
                                                VerticalAlignment="Center">
                                        <Border x:Name="ExpanderIcon"
                                                Width="16" Height="16" Margin="0,0,2,0">
                                            <Path x:Name="Arrow"
                                                  Data="M 4 2 L 12 6 L 4 10 Z"
                                                  Fill="{StaticResource TextDimBrush}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"
                                                  RenderTransformOrigin="0.5,0.5">
                                                <Path.RenderTransform>
                                                    <RotateTransform Angle="0" />
                                                </Path.RenderTransform>
                                            </Path>
                                        </Border>
                                        <TextBlock Text="{Binding Name}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding FullPath}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Col 1: File count -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding FileCountText}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Padding="8,0,8,0" />

                                <!-- Col 2: Size (bytes) -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding SizeText}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           FontSize="11"
                                           Foreground="{StaticResource TextDimBrush}"
                                           Padding="8,0,8,0" />
                            </Grid>

                            <ItemsPresenter x:Name="ItemsHost" Visibility="Collapsed" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="ExpanderIcon" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                <Setter TargetName="NameArea" Property="Cursor" Value="Hand" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===========================================================
             Custom TreeView: a clickable Name / Files / Size header row
             over a scrollable item area.  Both share a SizeScope so the
             columns line up; the header's right margin shifts when the
             scrollbar is showing.  Header clicks bind to the sort commands
             on the TreeView's DataContext (the ReviewTreeViewModel).
             ============================================================ -->
        <Style x:Key="ReviewTreeView" TargetType="TreeView">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeView">
                        <Border Grid.IsSharedSizeScope="True"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BorderBrush}"
                                Background="{StaticResource SurfaceBrush}">
                            <DockPanel>
                                <Grid DockPanel.Dock="Top">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ComputedVerticalScrollBarVisibility, ElementName=ReviewTreeScroll}" Value="Visible">
                                                    <Setter Property="Margin" Value="0,0,17,0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" MinWidth="64" SharedSizeGroup="ReviewFilesCol" />
                                        <ColumnDefinition Width="Auto" MinWidth="96" SharedSizeGroup="ReviewSizeCol" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Name / Directory header -->
                                    <Border Grid.Column="0"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,1,1"
                                            Padding="8,4"
                                            Cursor="Hand"
                                            Background="Transparent">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding SortByNameCommand}" />
                                        </Border.InputBindings>
                                        <TextBlock FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}">
                                            <Run Text="Name" /><Run Text="{Binding NameSortIndicator, Mode=OneWay}" />
                                        </TextBlock>
                                    </Border>

                                    <!-- Files header -->
                                    <Border Grid.Column="1"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,1,1"
                                            Padding="8,4"
                                            Cursor="Hand"
                                            Background="Transparent">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding SortByFilesCommand}" />
                                        </Border.InputBindings>
                                        <TextBlock FontSize="10"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Right"
                                                   Foreground="{StaticResource TextSecondaryBrush}">
                                            <Run Text="Files" /><Run Text="{Binding FilesSortIndicator, Mode=OneWay}" />
                                        </TextBlock>
                                    </Border>

                                    <!-- Size header -->
                                    <Border Grid.Column="2"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="8,4"
                                            Cursor="Hand"
                                            Background="Transparent">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding SortBySizeCommand}" />
                                        </Border.InputBindings>
                                        <TextBlock FontSize="10"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Right"
                                                   Foreground="{StaticResource TextSecondaryBrush}">
                                            <Run Text="Size (bytes)" /><Run Text="{Binding SizeSortIndicator, Mode=OneWay}" />
                                        </TextBlock>
                                    </Border>
                                </Grid>

                                <ScrollViewer x:Name="ReviewTreeScroll"
                                              Focusable="False"
                                              CanContentScroll="True"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto"
                                              Padding="0">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding HeaderText}"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="12" Margin="0,0,0,12" />

        <TreeView Grid.Row="1"
                  ItemsSource="{Binding RootNodes}"
                  Style="{StaticResource ReviewTreeView}"
                  ItemContainerStyle="{StaticResource ReviewTreeViewItem}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  b:BubbleScrollWheel.IsEnabled="True">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type vm:ReviewTreeNode}"
                                          ItemsSource="{Binding Children}" />
            </TreeView.ItemTemplate>
        </TreeView>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Not now" Padding="16,8" Margin="0,0,8,0"
                    Cursor="Hand" IsCancel="True"
                    Click="NotNow_Click" />
            <Button Style="{StaticResource PrimaryButton}"
                    Content="{Binding ConfirmButtonText}" Padding="16,8"
                    Cursor="Hand" IsDefault="True"
                    Click="Confirm_Click" />
        </StackPanel>
    </Grid>
</Window>
