<UserControl x:Class="LithicBackup.Views.SourceSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LithicBackup.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SourceSelectionViewModel, IsDesignTimeCreatable=False}">

    <DockPanel>
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource H2}" Text="Select Source Files" />
            <TextBlock Style="{StaticResource SubText}"
                       Text="Check the files and directories you want to include in this backup." />
        </StackPanel>

        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}"
                    Padding="16,8" Margin="0,0,8,0" Cursor="Hand" />
            <Button Style="{StaticResource PrimaryButton}"
                    Content="Next" Command="{Binding NextCommand}" />
        </StackPanel>

        <!-- TreeView with integrated column headers -->
        <TreeView ItemsSource="{Binding Roots}">

            <!-- Custom TreeView ControlTemplate: column headers + items in one visual tree -->
            <TreeView.Template>
                <ControlTemplate TargetType="TreeView">
                    <Border Grid.IsSharedSizeScope="True"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource SurfaceBrush}">
                        <DockPanel>
                            <!-- Column header row -->
                            <Grid DockPanel.Dock="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="AutoIncludeCol" />
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="VersionsCol" />
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="IncludeCol" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,1,1"
                                        Padding="4,6">
                                    <CheckBox IsChecked="{Binding IsAllAutoIncludeNew, Mode=TwoWay}"
                                              IsThreeState="False"
                                              Content="Auto-include new"
                                              FontSize="11"
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              VerticalContentAlignment="Center"
                                              ToolTip="Check/uncheck all auto-include" />
                                </Border>
                                <Border Grid.Column="1"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,1,1"
                                        Padding="4,6">
                                    <CheckBox IsChecked="{Binding IsAllKeepVersionHistory, Mode=TwoWay}"
                                              IsThreeState="False"
                                              Content="Keep versions"
                                              FontSize="11"
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              VerticalContentAlignment="Center"
                                              ToolTip="Keep previous versions when files change" />
                                </Border>
                                <Border Grid.Column="2"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="4,6">
                                    <CheckBox IsChecked="{Binding IsAllSelected, Mode=TwoWay}"
                                              IsThreeState="False"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              ToolTip="Check/uncheck all" />
                                </Border>
                                <Border Grid.Column="3"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1" />
                            </Grid>

                            <!-- Scrollable tree items -->
                            <ScrollViewer Focusable="False"
                                          CanContentScroll="False"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="0">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </TreeView.Template>

            <!-- Custom TreeViewItem template: fixed checkbox columns + indented name -->
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TreeViewItem">
                                <StackPanel>
                                    <!-- This node's row -->
                                    <Grid MinHeight="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="AutoIncludeCol" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="VersionsCol" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="IncludeCol" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Col 0: Auto-include new (fixed position, not indented) -->
                                        <Border Grid.Column="0"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="0,0,1,0">
                                            <CheckBox IsChecked="{Binding AutoIncludeNew, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      ToolTip="Auto-include new subdirectories"
                                                      Visibility="{Binding IsDirectory, Converter={StaticResource BoolToVis}}" />
                                        </Border>

                                        <!-- Col 1: Keep versions -->
                                        <Border Grid.Column="1"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="0,0,1,0">
                                            <CheckBox IsChecked="{Binding KeepVersionHistory, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      ToolTip="Keep previous versions when this file/directory changes" />
                                        </Border>

                                        <!-- Col 2: Include -->
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  IsThreeState="False"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center" />

                                        <!-- Col 3: Clickable name area (single-click expands directories) -->
                                        <Border x:Name="NameArea" Grid.Column="3"
                                                Background="Transparent">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding ToggleExpandCommand}" />
                                            </Border.InputBindings>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="{Binding Depth, Converter={StaticResource DepthToIndent}}"
                                                        VerticalAlignment="Center">
                                                <!-- Expand arrow (visual indicator, rotates when expanded) -->
                                                <Border x:Name="ExpanderIcon"
                                                        Width="16" Height="16" Margin="0,0,2,0">
                                                    <Path x:Name="Arrow"
                                                          Data="M 4 2 L 12 6 L 4 10 Z"
                                                          Fill="{StaticResource TextDimBrush}"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"
                                                          RenderTransformOrigin="0.5,0.5">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="0" />
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Border>
                                                <!-- Name -->
                                                <ContentPresenter x:Name="PART_Header"
                                                                  ContentSource="Header"
                                                                  VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Children (full width — no column offset, so child
                                         checkbox columns stay aligned with parent's) -->
                                    <ItemsPresenter x:Name="ItemsHost" Visibility="Collapsed" />
                                </StackPanel>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsExpanded" Value="True">
                                        <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                            <Setter.Value>
                                                <RotateTransform Angle="90" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="HasItems" Value="False">
                                        <Setter TargetName="ExpanderIcon" Property="Visibility" Value="Hidden" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                        <Setter TargetName="NameArea" Property="Cursor" Value="Hand" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TreeView.ItemContainerStyle>

            <!-- Data template: just the name (checkboxes are in the ControlTemplate) -->
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding Name}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </DockPanel>
</UserControl>
