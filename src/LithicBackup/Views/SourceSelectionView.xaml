<UserControl x:Class="LithicBackup.Views.SourceSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LithicBackup.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SourceSelectionViewModel, IsDesignTimeCreatable=False}">

    <DockPanel>
        <!-- Bottom: summary + buttons (persistent footer, outside the tabs) -->
        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Selected size summary -->
            <TextBlock Grid.Column="0"
                       Text="{Binding SelectedSizeText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12"
                       VerticalAlignment="Center" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Save status indicator (edit mode) -->
                <TextBlock Text="{Binding SaveStatusText}"
                           Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,12,0"
                           Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}" />

                <!-- Edit mode: Cancel + Save (Save primary on the right, matching
                     the Settings dialog and this window's own new-set footer) -->
                <Button Content="Cancel" Command="{Binding CancelCommand}"
                        Padding="16,8" Margin="0,0,8,0" Cursor="Hand"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}" />
                <Button Content="Save" Command="{Binding SaveCommand}"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                        ToolTipService.ShowOnDisabled="True"
                        ToolTipService.InitialShowDelay="0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="ToolTip"
                                            Value="No changes to save." />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- New-set mode: Cancel + Next -->
                <Button Content="Cancel" Command="{Binding CancelCommand}"
                        Padding="16,8" Margin="0,0,8,0" Cursor="Hand"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                <Button Content="Next" Command="{Binding NextCommand}"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                        ToolTipService.ShowOnDisabled="True"
                        ToolTipService.InitialShowDelay="0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="ToolTip"
                                            Value="Select at least one file or directory to back up." />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Top-level tabs: Sources hierarchy first, then the backup settings. -->
        <TabControl x:Name="EditorTabs"
                    SelectionChanged="EditorTabs_SelectionChanged">

            <!-- ===================== Sources ===================== -->
            <TabItem Header="Sources">
            <DockPanel>
                <!-- Source toolbar -->
                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="+ Add Network/Custom Folder"
                                    Command="{Binding AddPathCommand}"
                                    Padding="10,6" Margin="0,0,8,0" Cursor="Hand"
                                    ToolTip="Add a network share or unmapped drive as a backup source." />
                            <Button Content="Largest Files &amp; Directories"
                                    Command="{Binding LargestFilesCommand}"
                                    Padding="10,6" Margin="0,0,8,0" Cursor="Hand"
                                    Visibility="{Binding ShowLargestFiles, Converter={StaticResource BoolToVis}}"
                                    ToolTip="View the largest files and directories in this backup set's sources." />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox Content="Show sizes" IsChecked="{Binding ShowSizes}"
                                      VerticalAlignment="Center" Margin="0,0,8,0"
                                      ToolTip="Display file and directory sizes (computed in background)." />
                            <CheckBox Content="Selected only" IsChecked="{Binding ShowSelectedSizesOnly}"
                                      IsEnabled="{Binding ShowSizes}"
                                      VerticalAlignment="Center"
                                      ToolTip="Only show sizes for selected (checked) items." />
                        </StackPanel>
                    </Grid>
                    <!-- Size report (auto-populated when background sizes are ready) -->
                    <TextBlock Text="{Binding SizeCalculationResult}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" Margin="0,4,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SizeCalculationResult}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Tree + exclusion patterns (share the vertical space) -->
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="120" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="120" MinHeight="72" />
                </Grid.RowDefinitions>

                <!-- TreeView with integrated column headers -->
                <TreeView Grid.Row="0"
                          x:Name="SourceTree"
                          ItemsSource="{Binding Roots}"
                          BorderThickness="0"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          VirtualizingPanel.ScrollUnit="Pixel">

            <!-- Custom TreeView ControlTemplate: column headers + items in one visual tree -->
            <TreeView.Template>
                <ControlTemplate TargetType="TreeView">
                    <Border Grid.IsSharedSizeScope="True"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource SurfaceBrush}">
                        <DockPanel>
                            <!-- Column header row.
                                 Right margin compensates for the scrollbar width so
                                 header columns stay aligned with the item rows inside
                                 the ScrollViewer. -->
                            <Grid DockPanel.Dock="Top">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ComputedVerticalScrollBarVisibility, ElementName=TreeScroll}" Value="Visible">
                                                <Setter Property="Margin" Value="0,0,17,0" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="AutoIncludeCol" />
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="IncludeCol" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" MinWidth="56" SharedSizeGroup="FilesCol" />
                                    <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="SizeCol" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,1,1"
                                        Padding="4,6">
                                    <CheckBox IsChecked="{Binding IsAllAutoIncludeNew, Mode=TwoWay}"
                                              IsThreeState="False"
                                              Content="Auto-include new"
                                              FontSize="11"
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              VerticalContentAlignment="Center"
                                              ToolTip="Check/uncheck all auto-include"
                                              Visibility="{Binding IsApplyingSelections,
                                                           Converter={StaticResource BoolToVis},
                                                           ConverterParameter='Invert,Hidden'}" />
                                </Border>
                                <Border Grid.Column="1"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,1,1"
                                        Padding="4,6">
                                    <CheckBox IsChecked="{Binding IsAllSelected, Mode=TwoWay}"
                                              IsThreeState="False"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              ToolTip="Check/uncheck all"
                                              Visibility="{Binding IsApplyingSelections,
                                                           Converter={StaticResource BoolToVis},
                                                           ConverterParameter='Invert,Hidden'}" />
                                </Border>
                                <Border Grid.Column="2"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,1,1"
                                        Padding="4,6"
                                        Cursor="Hand"
                                        Background="Transparent">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding SortByNameCommand}" />
                                    </Border.InputBindings>
                                    <TextBlock FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}">
                                        <Run Text="Name" /><Run Text="{Binding NameSortIndicator, Mode=OneWay}" />
                                    </TextBlock>
                                </Border>
                                <Border Grid.Column="3"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,1,1"
                                        Padding="8,6"
                                        Background="Transparent">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowSizes}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextAlignment="Right"
                                               Text="Files" />
                                </Border>
                                <Border Grid.Column="4"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="8,6"
                                        Cursor="Hand"
                                        Background="Transparent">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowSizes}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding SortBySizeCommand}" />
                                    </Border.InputBindings>
                                    <TextBlock FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextAlignment="Right">
                                        <Run Text="Size" /><Run Text="{Binding SizeSortIndicator, Mode=OneWay}" />
                                    </TextBlock>
                                </Border>
                            </Grid>

                            <!-- Scrollable tree items -->
                            <ScrollViewer x:Name="TreeScroll"
                                          Focusable="False"
                                          CanContentScroll="True"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="0">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </TreeView.Template>

            <!-- Custom TreeViewItem template: fixed checkbox columns + indented name -->
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <EventSetter Event="RequestBringIntoView"
                                 Handler="TreeViewItem_RequestBringIntoView" />
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TreeViewItem">
                                <StackPanel>
                                    <!-- This node's row -->
                                    <Grid MinHeight="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="AutoIncludeCol" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="IncludeCol" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" MinWidth="56" SharedSizeGroup="FilesCol" />
                                            <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="SizeCol" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Col 0: Auto-include new (fixed position, not indented) -->
                                        <Border Grid.Column="0"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="0,0,1,0">
                                            <CheckBox IsChecked="{Binding AutoIncludeNew, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      ToolTip="Auto-include new subdirectories">
                                                <CheckBox.Style>
                                                    <Style TargetType="CheckBox">
                                                        <!-- Files never get this checkbox. Directories show it,
                                                             but only once THIS node's selection state has
                                                             settled (IsSelectionRestored); until then it's
                                                             Hidden (not Collapsed) so the column keeps its
                                                             width and nothing shifts when the box appears.
                                                             Per-node (not the global IsApplyingSelections flag)
                                                             so boxes reveal top-down as each row restores. -->
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                                <Setter Property="Visibility" Value="Hidden" />
                                                            </DataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsDirectory}" Value="True" />
                                                                    <Condition Binding="{Binding IsSelectionRestored}" Value="True" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                            <DataTrigger Binding="{Binding IsNodeEnabled}" Value="False">
                                                                <Setter Property="Opacity" Value="0.35" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </CheckBox.Style>
                                            </CheckBox>
                                        </Border>

                                        <!-- Col 1: Include -->
                                        <Border Grid.Column="1"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="0,0,1,0">
                                            <!-- Hidden (not collapsed, so its column keeps its width and
                                                 nothing shifts) until THIS node's selection state has
                                                 settled, so the user never sees a full column of unchecked
                                                 boxes and fears their sources were lost.  Bound per-node
                                                 (IsSelectionRestored) rather than to the global
                                                 IsApplyingSelections flag so checkboxes appear top-down as
                                                 each row's state is restored, instead of all at once after
                                                 the entire (deep) restore finishes. -->
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      IsThreeState="False"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      Visibility="{Binding IsSelectionRestored,
                                                                   Converter={StaticResource BoolToVis},
                                                                   ConverterParameter='Hidden'}" />
                                        </Border>

                                        <!-- Col 2: Clickable name area (single-click expands directories) -->
                                        <Border x:Name="NameArea" Grid.Column="2"
                                                Background="Transparent"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="0,0,1,0">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding ToggleExpandCommand}" />
                                            </Border.InputBindings>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="{Binding Depth, Converter={StaticResource DepthToIndent}}"
                                                        VerticalAlignment="Center">
                                                <!-- Expand arrow (visual indicator, rotates when expanded) -->
                                                <Border x:Name="ExpanderIcon"
                                                        Width="16" Height="16" Margin="0,0,2,0">
                                                    <Path x:Name="Arrow"
                                                          Data="M 4 2 L 12 6 L 4 10 Z"
                                                          Fill="{StaticResource TextDimBrush}"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"
                                                          RenderTransformOrigin="0.5,0.5">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="0" />
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Border>
                                                <!-- Name -->
                                                <ContentPresenter x:Name="PART_Header"
                                                                  ContentSource="Header"
                                                                  VerticalAlignment="Center" />
                                                <!-- Backup status dot (wrapped for reliable tooltip hit-testing) -->
                                                <Border x:Name="StatusDotArea"
                                                        Background="Transparent"
                                                        Padding="3"
                                                        Margin="2,0,0,0"
                                                        VerticalAlignment="Center"
                                                        ToolTipService.InitialShowDelay="0"
                                                        Visibility="Collapsed">
                                                    <Ellipse x:Name="StatusDot"
                                                             Width="7" Height="7" />
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <!-- Col 3: File count (visible only when ShowSizes is on) -->
                                        <Border Grid.Column="3"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="0,0,1,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.ShowSizes,
                                                                     RelativeSource={RelativeSource AncestorType=TreeView}}"
                                                                     Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding FormattedFileCount}"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Right"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Padding="8,0,8,0" />
                                        </Border>

                                        <!-- Col 4: Size (visible only when ShowSizes is on) -->
                                        <Border Grid.Column="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.ShowSizes,
                                                                     RelativeSource={RelativeSource AncestorType=TreeView}}"
                                                                     Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding FormattedSize}"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Right"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Padding="8,0,8,0" />
                                        </Border>
                                    </Grid>

                                    <!-- Children (full width — no column offset, so child
                                         checkbox columns stay aligned with parent's) -->
                                    <ItemsPresenter x:Name="ItemsHost" Visibility="Collapsed" />
                                </StackPanel>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsExpanded" Value="True">
                                        <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                            <Setter.Value>
                                                <RotateTransform Angle="90" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="HasItems" Value="False">
                                        <Setter TargetName="ExpanderIcon" Property="Visibility" Value="Hidden" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                        <Setter TargetName="NameArea" Property="Cursor" Value="Hand" />
                                    </DataTrigger>

                                    <!-- Backup status dot colors -->
                                    <DataTrigger Binding="{Binding BackupStatus}" Value="{x:Static vm:BackupStatus.BackedUp}">
                                        <Setter TargetName="StatusDotArea" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="StatusDot" Property="Fill" Value="#2E7D32" />
                                        <Setter TargetName="StatusDotArea" Property="ToolTip" Value="Backed up" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackupStatus}" Value="{x:Static vm:BackupStatus.Changed}">
                                        <Setter TargetName="StatusDotArea" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="StatusDot" Property="Fill" Value="#EF6C00" />
                                        <Setter TargetName="StatusDotArea" Property="ToolTip" Value="Changed since last backup" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackupStatus}" Value="{x:Static vm:BackupStatus.NotBackedUp}">
                                        <Setter TargetName="StatusDotArea" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="StatusDot" Property="Fill" Value="#C62828" />
                                        <Setter TargetName="StatusDotArea" Property="ToolTip" Value="Not backed up" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackupStatus}" Value="{x:Static vm:BackupStatus.Partial}">
                                        <Setter TargetName="StatusDotArea" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="StatusDot" Property="Fill" Value="#F9A825" />
                                        <Setter TargetName="StatusDotArea" Property="ToolTip" Value="Partially backed up" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TreeView.ItemContainerStyle>

            <!-- Data template: just the name (checkboxes are in the ControlTemplate).
                 Hidden/System entries (e.g. C:\ProgramData) are shown but painted a
                 distinct violet so it's clear they're special. -->
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHiddenOrSystem}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource HiddenSystemBrush}" />
                                        <Setter Property="ToolTip" Value="Hidden or system item" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <!-- Drag handle: let the user trade vertical space between the tree and
             the exclusion panel. -->
        <GridSplitter Grid.Row="1" Height="6"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Background="Transparent" Cursor="SizeNS"
                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" />

        <!-- Exclude-from-backup patterns (shares the tree's space). -->
        <Border Grid.Row="2"
                BorderThickness="1"
                BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource SurfaceBrush}">
            <DockPanel Margin="10">
                <TextBlock DockPanel.Dock="Top" Text="Exclude from Backup"
                           FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock DockPanel.Dock="Top"
                           Text="Glob patterns, one per line. Matching files are not backed up."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBox Text="{Binding ExcludedExtensions, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         Padding="6,4"
                         BorderBrush="{StaticResource BorderBrush}"
                         FontFamily="Consolas, Courier New, monospace"
                         FontSize="12"
                         ToolTip="Examples:  *.log  *.tmp  *.bak  */.vs/*  */bin/*  */obj/*&#x0a;&#x0a;Use * to match any characters in a file name.&#x0a;Use */ to match directory paths." />
            </DockPanel>
        </Border>
                </Grid>
            </DockPanel>
            </TabItem>

            <!-- ===================== General ===================== -->
            <TabItem Header="General">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Focusable="False" Padding="2,10,6,0">
            <StackPanel>

                <!-- Name -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Name:"
                               VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Grid.Column="1"
                             Text="{Binding SetName, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4"
                             BorderBrush="{StaticResource BorderBrush}" />
                </Grid>



                <!-- Target mode -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton Content="Backup to Disc"
                                 IsChecked="True"
                                 GroupName="TargetMode"
                                 Margin="0,0,16,0"
                                 VerticalContentAlignment="Center"
                                 x:Name="DiscModeRadio" />
                    <RadioButton Content="Backup to Directory"
                                 IsChecked="{Binding IsDirectoryMode, Mode=TwoWay}"
                                 GroupName="TargetMode"
                                 VerticalContentAlignment="Center" />
                </StackPanel>

                <!-- Directory target path (directory mode) -->
                <Grid Margin="0,0,0,8"
                      Visibility="{Binding IsDirectoryMode, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Destination:"
                               VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Grid.Column="1"
                             Text="{Binding TargetDirectory, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4"
                             BorderBrush="{StaticResource BorderBrush}"
                             ToolTip="Path to the backup target directory" />
                    <Button Grid.Column="2" Content="..."
                            Command="{Binding BrowseDirectoryCommand}"
                            Padding="8,4" Margin="4,0,0,0" Cursor="Hand" />
                </Grid>

                <!-- Destination drive space (directory mode) -->
                <TextBlock Text="{Binding DestinationSpaceText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,0,0,6">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDirectoryMode}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DestinationSpaceText}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Subdirectory option (directory mode) -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                            Visibility="{Binding IsDirectoryMode, Converter={StaticResource BoolToVis}}">
                    <CheckBox Content="Create subdirectory:"
                              IsChecked="{Binding CreateSubdirectory, Mode=TwoWay}"
                              VerticalContentAlignment="Center"
                              Margin="0,0,8,0" />
                    <TextBox Text="{Binding SubdirectoryName, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4" Width="250"
                             BorderBrush="{StaticResource BorderBrush}"
                             IsEnabled="{Binding CreateSubdirectory}" />
                </StackPanel>

                <!-- Seed from existing mirror backup (directory mode, edit mode) -->
                <StackPanel Margin="0,0,0,8"
                            Visibility="{Binding IsDirectoryMode, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding SeedFromExistingCommand}"
                                Padding="10,6" Margin="0,0,8,0" Cursor="Hand"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                                ToolTip="Import files from an existing mirror backup (e.g. backup4all) in the destination directory so future backups are incremental.">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Seed from Existing Backup" />
                                <TextBlock Text=" ..." Visibility="{Binding IsSeeding, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </Button>
                        <Button Content="Cancel" Command="{Binding CancelSeedCommand}"
                                Padding="10,6" Margin="0,0,8,0" Cursor="Hand"
                                Visibility="{Binding IsSeeding, Converter={StaticResource BoolToVis}}" />
                        <CheckBox Content="Skip hashing (fast)"
                                  IsChecked="{Binding SeedSkipHashing}"
                                  VerticalContentAlignment="Center"
                                  Margin="0,0,12,0"
                                  Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                                  ToolTip="Skip SHA-256 hashing during import. Much faster — incremental detection uses file size and timestamps, not content hashes." />
                        <TextBlock Text="{Binding SeedResult}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" VerticalAlignment="Center"
                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SeedResult}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Clear backup history (edit mode) -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                    <Button Content="Clear Backup History"
                            Command="{Binding ClearHistoryCommand}"
                            Padding="10,6" Margin="0,0,8,0" Cursor="Hand"
                            ToolTip="Delete this set's catalog records of what has been backed up (discs and file entries), keeping all settings. The next backup treats every source file as new. Files already on the destination are not deleted." />
                    <TextBlock Text="{Binding ClearHistoryResult}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center"
                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ClearHistoryResult}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
            </ScrollViewer>
            </TabItem>

            <!-- ===================== Options ===================== -->
            <TabItem Header="Options">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Focusable="False" Padding="2,10,6,0">
            <StackPanel>

                <!-- ====== Disc-mode options ====== -->
                <StackPanel Visibility="{Binding IsDirectoryMode, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Zip mode:"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ZipModeOptions}"
                                  SelectedItem="{Binding ZipMode}"
                                  Padding="4,3" />
                        <TextBlock Grid.Column="3" Text="Filesystem:"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox Grid.Column="4"
                                  ItemsSource="{Binding FilesystemTypeOptions}"
                                  SelectedItem="{Binding FilesystemType}"
                                  Padding="4,3" />
                        <TextBlock Grid.Column="6" Text="Capacity (GB):"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBox Grid.Column="7"
                                 Text="{Binding CapacityOverrideGb, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="4,3"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 ToolTip="Override disc capacity in GB (leave blank for auto-detect)" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <CheckBox Content="Verify after burn"
                                  IsChecked="{Binding VerifyAfterBurn}"
                                  Margin="0,0,16,0" />
                        <CheckBox Content="Include catalog on disc"
                                  IsChecked="{Binding IncludeCatalogOnDisc}"
                                  Margin="0,0,16,0" />
                        <CheckBox Content="Allow file splitting"
                                  IsChecked="{Binding AllowFileSplitting}" />
                    </StackPanel>
                </StackPanel>

                <!-- ====== Directory-mode options ====== -->
                <StackPanel Visibility="{Binding IsDirectoryMode, Converter={StaticResource BoolToVis}}">

                    <!-- Deduplication -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <CheckBox Content="File-level dedup"
                                  IsChecked="{Binding EnableFileDeduplication}"
                                  VerticalContentAlignment="Center"
                                  Margin="0,0,16,0" />
                        <CheckBox Content="Block-level dedup"
                                  IsChecked="{Binding EnableBlockDeduplication}"
                                  VerticalContentAlignment="Center"
                                  Margin="0,0,8,0" />
                        <TextBlock Text="Block size:"
                                   VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBox Text="{Binding BlockSizeKb, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="4,3" Width="60"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 IsEnabled="{Binding EnableBlockDeduplication}" />
                        <TextBlock Text="KB" VerticalAlignment="Center" Margin="4,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            </ScrollViewer>
            </TabItem>

            <!-- ===================== Retention ===================== -->
            <TabItem Header="Retention">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Focusable="False" Padding="2,10,6,0">
            <StackPanel>
                <TextBlock Text="Version retention tiers apply to directory backups only."
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,0,0,4"
                           Visibility="{Binding IsDirectoryMode, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                <StackPanel Visibility="{Binding IsDirectoryMode, Converter={StaticResource BoolToVis}}">

                    <!-- Version retention tier sets -->
                    <TextBlock Text="Version Retention Tier Sets" FontWeight="SemiBold"
                               Margin="0,0,0,4" FontSize="12" />

                    <!-- Tier set selector -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <ComboBox ItemsSource="{Binding TierSets}"
                                  SelectedItem="{Binding SelectedTierSet}"
                                  DisplayMemberPath="Name"
                                  Padding="4,3" MinWidth="120"
                                  ToolTipService.ShowDuration="30000">
                            <ComboBox.ToolTip>
                                <TextBlock MaxWidth="360" TextWrapping="Wrap">
                                    Picks which tier set to view and edit below — <Run FontWeight="SemiBold">not</Run> which one is &quot;active.&quot;
                                    All tier sets are always in effect: at backup time each file is assigned to the first
                                    tier set whose file patterns match its path, and any file matched by none falls back
                                    to <Run FontStyle="Italic">Default</Run>. This dropdown only chooses which set's tiers and
                                    patterns you're editing.
                                </TextBlock>
                            </ComboBox.ToolTip>
                        </ComboBox>
                        <Button Content="+ New" Command="{Binding AddTierSetCommand}"
                                Padding="8,4" Margin="6,0,0,0" Cursor="Hand" FontSize="11"
                                ToolTip="Create a new custom tier set" />
                        <Button Content="&#x2715; Remove" Command="{Binding RemoveTierSetCommand}"
                                Padding="8,4" Margin="4,0,0,0" Cursor="Hand" FontSize="11"
                                ToolTip="Remove the selected tier set" />
                    </StackPanel>

                    <!-- Tier set name editor (custom sets only) -->
                    <Grid Margin="20,0,0,4">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTierSet.IsBuiltIn}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Name:"
                                   VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding SelectedTierSet.Name, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="4,3" FontSize="11"
                                 BorderBrush="{StaticResource BorderBrush}" />
                    </Grid>

                    <!-- File pattern matching (not shown for "Default" — it's the fallback) -->
                    <StackPanel Margin="20,0,0,4">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTierSet.Name}" Value="Default">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Match files:" FontSize="11" Margin="0,0,0,2"
                                   ToolTip="Glob patterns for files that use this tier set (e.g. *.log, *\Temp\*)" />
                        <TextBox Text="{Binding SelectedTierSet.FilePatternsText, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="11" Padding="4,3"
                                 AcceptsReturn="True" Height="60"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 ToolTip="One glob pattern per line (e.g. *.log, *.tmp, *\Temp\*)" />
                        <TextBlock Text="Exempt files:" FontSize="11" Margin="0,6,0,2"
                                   ToolTip="Glob patterns to exclude from matching (override the patterns above)" />
                        <TextBox Text="{Binding SelectedTierSet.FileExemptPatternsText, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="11" Padding="4,3"
                                 AcceptsReturn="True" Height="40"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 ToolTip="One glob pattern per line — files matching these are NOT assigned to this tier set" />
                        <Button Content="Apply"
                                Command="{Binding ApplyFiltersCommand}"
                                FontSize="11" Padding="10,2" Margin="0,4,0,0"
                                HorizontalAlignment="Left"
                                ToolTip="Apply the current filter patterns to recalculate sizes" />
                    </StackPanel>

                    <!-- "Default" description -->
                    <TextBlock Margin="20,0,0,4" FontSize="11" FontStyle="Italic"
                               Foreground="{StaticResource TextDimBrush}"
                               Text="Fallback tier set — applies to all files not matched by another tier set.">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTierSet.Name}" Value="Default">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- "None" description -->
                    <TextBlock Margin="20,0,0,4" FontSize="11" FontStyle="Italic"
                               Foreground="{StaticResource TextDimBrush}"
                               Text="Excluded from backup — matching files are not saved.">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTierSet.Name}" Value="None">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Retention tiers of the selected set -->
                    <StackPanel Margin="20,0,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanEditSelectedTierSet}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <ItemsControl ItemsSource="{Binding SelectedTierSet.Tiers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="Under" VerticalAlignment="Center"
                                                   Margin="0,0,4,0" />
                                        <Grid Width="60">
                                            <TextBox Text="{Binding MaxAgeDays, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="4,3" x:Name="AgeDaysBox"
                                                     BorderBrush="{StaticResource BorderBrush}"
                                                     ToolTip="Days (leave empty for catch-all)" />
                                            <TextBlock Text="any" IsHitTestVisible="False"
                                                       Foreground="{StaticResource TextDimBrush}"
                                                       VerticalAlignment="Center" Margin="6,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, ElementName=AgeDaysBox}"
                                                                         Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                        <TextBlock Text="days, keep" VerticalAlignment="Center"
                                                   Margin="4,0,4,0" />
                                        <Grid Width="50">
                                            <TextBox Text="{Binding MaxVersions, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="4,3" x:Name="MaxVersionsBox"
                                                     BorderBrush="{StaticResource BorderBrush}"
                                                     ToolTip="Max versions (leave empty for all)" />
                                            <TextBlock Text="all" IsHitTestVisible="False"
                                                       Foreground="{StaticResource TextDimBrush}"
                                                       VerticalAlignment="Center" Margin="6,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, ElementName=MaxVersionsBox}"
                                                                         Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                        <TextBlock Text="versions" VerticalAlignment="Center"
                                                   Margin="4,0,8,0" />
                                        <Button Content="&#x2715;" Command="{Binding RemoveCommand}"
                                                Padding="4,2" Cursor="Hand" FontSize="11" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Add Tier" Command="{Binding AddRetentionTierCommand}"
                                HorizontalAlignment="Left"
                                Padding="8,4" Margin="0,2,0,6" Cursor="Hand" FontSize="11" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            </ScrollViewer>
            </TabItem>

            <!-- ===================== Schedule ===================== -->
            <TabItem Header="Schedule">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Focusable="False" Padding="2,10,6,0">
            <StackPanel>
                <TextBlock Text="Automated scheduling applies to directory backups only."
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,0,0,4"
                           Visibility="{Binding IsDirectoryMode, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                <StackPanel Visibility="{Binding IsDirectoryMode, Converter={StaticResource BoolToVis}}">

                    <!-- Schedule -->
                    <CheckBox Content="Enable automated backups"
                              IsChecked="{Binding ScheduleEnabled, Mode=TwoWay}"
                              FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6" />
                    <StackPanel IsEnabled="{Binding ScheduleEnabled}" Margin="0,0,0,2">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Mode:" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <ComboBox ItemsSource="{Binding ScheduleModeOptions}"
                                      SelectedItem="{Binding ScheduleMode}"
                                      Padding="4,3" Width="120" />
                        </StackPanel>
                        <!-- Interval -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ScheduleMode}" Value="Interval">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Every" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBox Text="{Binding ScheduleIntervalHours, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="4,3" Width="60"
                                     BorderBrush="{StaticResource BorderBrush}" />
                            <TextBlock Text="hours" VerticalAlignment="Center" Margin="6,0,0,0" />
                        </StackPanel>
                        <!-- Daily -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ScheduleMode}" Value="Daily">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Run at" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBox Text="{Binding ScheduleDailyHour, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="4,3" Width="40"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     ToolTip="Hour (0-23)" />
                            <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0,2,0" />
                            <TextBox Text="{Binding ScheduleDailyMinute, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="4,3" Width="40"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     ToolTip="Minute (0-59)" />
                        </StackPanel>
                        <!-- Continuous: settle time (debounce) and max-wait are now
                             machine-global rules (Settings ▸ Continuous), tiered by
                             file size and by name/path mask, so they aren't set here
                             per set. -->
                        <TextBlock Margin="0,0,0,4" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ScheduleMode}" Value="Continuous">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="Settle time and the max-wait cap are configured globally in Settings ▸ Continuous (tiered by file size and by name/path mask)." />
                        </TextBlock>
                        <!-- Continuous mode is driven by USN push notifications;
                             the old per-set poll interval was removed. The Worker
                             falls back to a global poll interval as a backstop. -->
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
