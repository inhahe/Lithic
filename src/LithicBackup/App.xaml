<Application x:Class="LithicBackup.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LithicBackup.Converters"
             ShutdownMode="OnExplicitShutdown"
>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global converters -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
            <converters:FileSizeConverter x:Key="FileSize" />
            <converters:DepthToIndentConverter x:Key="DepthToIndent" />
            <converters:IntEqualsVisibilityConverter x:Key="IntEqualsVis" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
