<Window x:Class="LithicBackup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:LithicBackup.ViewModels"
        xmlns:views="clr-namespace:LithicBackup.Views"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        Style="{StaticResource MainWindowStyle}"
        Title="Lithic Backup" Height="600" Width="900"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Style="{StaticResource H1}" Text="Lithic Backup" />
            <TextBlock Style="{StaticResource SubText}"
                       Text="Incremental disc backup with smart space management" />
        </StackPanel>

        <!-- Main content area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left sidebar: backup sets -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource H2}" Text="Backup Sets" />

                    <!-- Bottom buttons -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="New Backup Set"
                                HorizontalAlignment="Stretch"
                                Command="{Binding NewBackupSetCommand}" />
                        <Button Content="Run Incremental"
                                HorizontalAlignment="Stretch"
                                Padding="16,8" Margin="0,6,0,0"
                                Cursor="Hand"
                                Command="{Binding RunIncrementalCommand}" />
                        <Button Content="Restore Files"
                                HorizontalAlignment="Stretch"
                                Padding="16,8" Margin="0,6,0,0"
                                Cursor="Hand"
                                Command="{Binding RestoreCommand}" />
                    </StackPanel>

                    <!-- Backup set list -->
                    <ListBox ItemsSource="{Binding BackupSets}"
                             SelectedItem="{Binding SelectedBackupSet}"
                             BorderThickness="0"
                             Background="Transparent"
                             Margin="0,8,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,4">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Foreground="{StaticResource TextDimBrush}"
                                               FontSize="11">
                                        <TextBlock.Text>
                                            <Binding Path="SourceRoots.Count"
                                                     StringFormat="{}{0} source(s)" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Right content area -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <ContentControl Content="{Binding CurrentView}">
                    <ContentControl.Resources>
                        <!-- Map viewmodel types to views -->
                        <DataTemplate DataType="{x:Type vm:SourceSelectionViewModel}">
                            <views:SourceSelectionView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:BackupJobViewModel}">
                            <views:BackupJobView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:BurnProgressViewModel}">
                            <views:BurnProgressView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:RestoreViewModel}">
                            <views:RestoreView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:OrphanedDirectoriesViewModel}">
                            <views:OrphanedDirectoriesView />
                        </DataTemplate>
                    </ContentControl.Resources>

                    <!-- Default content when CurrentView is null (home screen) -->
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentView}" Value="{x:Null}">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <StackPanel VerticalAlignment="Center"
                                                            HorizontalAlignment="Center">
                                                    <TextBlock Style="{StaticResource H2}"
                                                               HorizontalAlignment="Center"
                                                               Text="Welcome to Lithic Backup" />
                                                    <TextBlock Style="{StaticResource SubText}"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,4,0,0"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               MaxWidth="400"
                                                               Text="Create a new backup set or select an existing one from the sidebar to run an incremental backup." />
                                                    <TextBlock Style="{StaticResource SubText}"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,12,0,0"
                                                               Text="Supports CD, DVD, Blu-Ray, and M-Disc media." />

                                                    <!-- Backup-set-specific action (only when a set is selected) -->
                                                    <Button Content="Review Orphaned Directories"
                                                            HorizontalAlignment="Center"
                                                            Padding="16,8" Margin="0,24,0,0"
                                                            Cursor="Hand"
                                                            Command="{Binding DataContext.OrphanedDirsCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DataContext.SelectedBackupSet,
                                                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                 Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,8"
                Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" />
        </Border>
    </Grid>
</Window>
