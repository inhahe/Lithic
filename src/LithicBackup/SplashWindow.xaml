<Window x:Class="LithicBackup.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Width="340" Height="180"
        Topmost="True">

    <Border Background="#FFFFFF"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            CornerRadius="8"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.15"
                              BlurRadius="16" ShadowDepth="2"
                              Direction="270" />
        </Border.Effect>

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <TextBlock Text="Lithic Backup"
                       FontFamily="Segoe UI"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#1E293B"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Incremental disc backup"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       Foreground="#64748B"
                       HorizontalAlignment="Center"
                       Margin="0,2,0,16" />
            <ProgressBar IsIndeterminate="True"
                         Height="3" Width="180"
                         Foreground="#2563EB"
                         Background="#DBEAFE"
                         BorderThickness="0" />
            <TextBlock Text="Loading..."
                       FontFamily="Segoe UI"
                       FontSize="11"
                       Foreground="#94A3B8"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0" />
        </StackPanel>
    </Border>
</Window>
